---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import ServiceCard from "../components/content/ServiceCard.astro";
import GalleryGrid from "../components/content/GalleryGrid.astro";
import FAQAccordion from "../components/content/FAQAccordion.astro";
import ServiceAreaLinks from "../components/sections/ServiceAreaLinks.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import GoogleReviewsSection from "../components/sections/GoogleReviewsSection.astro";
import BookingCtaBlock from "../components/sections/BookingCtaBlock.astro";
import CTASection from "../components/sections/CTASection.astro";
import { services } from "../data/services";
import { commonFaqs } from "../data/faqs";
import { galleryItems } from "../data/gallery";
import {
	organizationJsonLd,
	localBusinessJsonLd,
	websiteJsonLd,
	faqJsonLd,
} from "../utils/schema";

// Show six owner-selected featured gallery items on the homepage — real photos only
const featuredGallery = galleryItems
	.filter(
		(item) =>
			item.permissionConfirmed &&
			item.featured &&
			!item.src.endsWith(".svg"),
	)
	.slice(0, 6)
	.map((item) => ({ src: item.src, alt: item.alt }));
---

<BaseLayout
	title="LA Face Painting & Kids Party Entertainment | Happy Faces LA"
	description="Professional face painting, balloons, glitter tattoos & face gems for kids' parties across Los Angeles. Call or text 818-619-5506 for availability & pricing."
	canonicalPath="/"
	jsonLd={[organizationJsonLd(), localBusinessJsonLd(), websiteJsonLd(), faqJsonLd(commonFaqs)]}
	homepageVisualBaseline="homepage-visual-baseline-v0.3-owner-gallery-20260616"
>
	<Hero
		title="Face Painting, Balloon Twisting & Glitter Tattoos in Los Angeles"
		subtitle="Professional kids party and event entertainment by Happy Faces LA, serving birthdays, school events, corporate family events, festivals, and private celebrations across Los Angeles."
		primaryCtaLabel="Plan My Party"
		primaryCtaHref="/plan-my-party/"
		heroImage="/images/hero/happy-faces-la-hero-face-painting-butterfly-01.webp"
		heroImageAlt="Butterfly face painting by Happy Faces LA at a birthday party in Los Angeles"
	/>

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<h2 class="text-2xl font-bold text-slate-900">Kids Party Entertainment Services in Los Angeles</h2>
		<p class="mt-4 max-w-3xl text-base leading-relaxed text-slate-700">
			Happy Faces LA brings professional, fully insured party entertainment to birthdays, school
			events, festivals, and corporate family days across Los Angeles — including Burbank, Glendale,
			Pasadena, Sherman Oaks, Studio City, and Encino. Every artist uses skin-safe,
			professional-grade paints and keeps lines moving so no child waits long.
		</p>
		<div class="mt-6 grid gap-4 md:grid-cols-2">
			{
				services.map((service) => (
					<ServiceCard
						title={service.name}
						description={service.description}
						href={`/${service.slug}/`}
						image={service.image}
						imageAlt={service.imageAlt}
						linkLabel={
							service.slug === "face-gems-face-jewelry-los-angeles"
								? "Face Gems for Parties in Los Angeles"
								: `${service.name} in Los Angeles`
						}
					/>
				))
			}
		</div>
	</section>

	<section class="mx-auto w-full max-w-6xl px-4 pb-2">
		<BookingCtaBlock
			title="Now booking soccer fan face painting and matchday fan paint bars."
			description="Fast, photo-ready country-color face painting, cheek flags, glitter, and gems for watch parties, fan zones, restaurants, bars, hotels, and sponsor activations across Los Angeles."
			primaryHref="/soccer-fan-face-painting-los-angeles/"
			primaryLabel="Book a Fan Paint Bar"
		/>
	</section>

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<GalleryGrid title="Recent Los Angeles Parties" images={featuredGallery} />
	</section>

	<GoogleReviewsSection
		heading="What our LA families say on Google"
		limit={3}
	/>

	<TestimonialsSection limit={6} />

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<ServiceAreaLinks />
	</section>

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<FAQAccordion items={commonFaqs} />
	</section>

	<section class="mx-auto w-full max-w-6xl px-4 pb-10">
		<CTASection ctaPrimaryLabel="Plan My Party" ctaPrimaryHref="/plan-my-party/" />
	</section>
</BaseLayout>
