---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import ServiceCard from "../components/content/ServiceCard.astro";
import PackageCard from "../components/content/PackageCard.astro";
import GalleryGrid from "../components/content/GalleryGrid.astro";
import FAQAccordion from "../components/content/FAQAccordion.astro";
import ServiceAreaLinks from "../components/sections/ServiceAreaLinks.astro";
import TrustSection from "../components/sections/TrustSection.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import CTASection from "../components/sections/CTASection.astro";
import { services } from "../data/services";
import { packages } from "../data/packages";
import { commonFaqs } from "../data/faqs";
import { galleryItems } from "../data/gallery";
import { organizationJsonLd, localBusinessJsonLd, websiteJsonLd } from "../utils/schema";

// Show up to 6 featured gallery items on the homepage
const featuredGallery = galleryItems
  .filter((item) => item.permissionConfirmed && item.featured)
  .slice(0, 6)
  .map((item) => ({ src: item.src, alt: item.alt }));
---

<BaseLayout
	title="Face Painting, Balloon Twisting & Glitter Tattoos in Los Angeles | Happy Faces LA"
	description="Book Happy Faces LA for professional face painting, balloon twisting, glitter tattoos, and face gems in Los Angeles. Call/text 818-619-5506 for availability and pricing."
	canonicalPath="/"
	jsonLd={[organizationJsonLd(), localBusinessJsonLd(), websiteJsonLd()]}
>
	<Hero
		title="Face Painting, Balloon Twisting & Glitter Tattoos in Los Angeles"
		subtitle="Professional kids party and event entertainment by Happy Faces LA, serving birthdays, school events, corporate family events, festivals, and private celebrations across Los Angeles."
	/>

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<h2 class="text-2xl font-bold text-slate-900">Core services</h2>
		<div class="mt-4 grid gap-4 md:grid-cols-2">
			{services.map((service) => (
				<ServiceCard title={service.name} description={service.description} href={`/${service.slug}/`} />
			))}
		</div>
	</section>

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<h2 class="text-2xl font-bold text-slate-900">Package preview</h2>
		<div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
			{packages.slice(0, 3).map((pkg) => <PackageCard {...pkg} />)}
		</div>
	</section>

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<GalleryGrid title="Recent events" images={featuredGallery} />
	</section>

	<TestimonialsSection limit={6} />

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<ServiceAreaLinks />
	</section>

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<TrustSection />
	</section>

	<section class="mx-auto w-full max-w-6xl px-4 py-10">
		<FAQAccordion items={commonFaqs} />
	</section>

	<section class="mx-auto w-full max-w-6xl px-4 pb-10">
		<CTASection />
	</section>
</BaseLayout>
