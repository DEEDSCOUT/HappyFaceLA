---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import FilteredGallery from "../components/content/FilteredGallery.astro";
import { galleryItems, galleryCategories } from "../data/gallery";

const canonicalPath = "/gallery/";
---

<BaseLayout
  title="Gallery | Happy Faces LA"
  description="Browse face painting, balloon twisting, glitter tattoo, and face gem event photos from Happy Faces LA in Los Angeles."
  canonicalPath={canonicalPath}
>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Gallery", href: canonicalPath }]} />
  <PageIntro title="Gallery" description="Face painting, balloon twisting, glitter tattoos, and face gems at parties and events. Serving Los Angeles and nearby areas." />

  <section class="mx-auto w-full max-w-6xl px-4 pt-4 pb-0">
    <p class="text-sm text-slate-600">
      View service details:
      <a href="/face-painting-los-angeles/" class="text-orange-600 hover:underline">Face Painting</a>
      <span class="mx-1 text-slate-300">·</span>
      <a href="/balloon-twisting-los-angeles/" class="text-orange-600 hover:underline">Balloon Twisting</a>
      <span class="mx-1 text-slate-300">·</span>
      <a href="/face-gems-face-jewelry-los-angeles/" class="text-orange-600 hover:underline">Face Gems</a>
      <span class="mx-1 text-slate-300">·</span>
      <a href="/glitter-tattoos-los-angeles/" class="text-orange-600 hover:underline">Glitter Tattoos</a>
      <span class="mx-1 text-slate-300">·</span>
      <a href="/services/" class="text-orange-600 hover:underline">All Services</a>
    </p>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 py-10">
    <FilteredGallery items={galleryItems} categories={galleryCategories} />
  </section>

  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: "gallery_view", source_page: window.location.pathname });
    if (typeof window.gtag === "function") {
      window.gtag("event", "gallery_view", { source_page: window.location.pathname });
    }
  </script>
</BaseLayout>
