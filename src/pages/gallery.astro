---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import FilteredGallery from "../components/content/FilteredGallery.astro";
import { galleryItems, galleryCategories } from "../data/gallery";

const canonicalPath = "/gallery/";
---

<BaseLayout
  title="Gallery | Happy Faces LA"
  description="Browse face painting, balloon twisting, glitter tattoo, and face gem event photos from Happy Faces LA in Los Angeles."
  canonicalPath={canonicalPath}
>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Gallery", href: canonicalPath }]} />
  <PageIntro title="Gallery" description="Face painting, balloon twisting, glitter tattoos, and face gems at parties and events across Los Angeles, Orange County, and Ventura County." />

  <section class="mx-auto w-full max-w-6xl px-4 py-10">
    <FilteredGallery items={galleryItems} categories={galleryCategories} />
  </section>

  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: "gallery_view", source_page: window.location.pathname });
    if (typeof window.gtag === "function") {
      window.gtag("event", "gallery_view", { source_page: window.location.pathname });
    }
  </script>
</BaseLayout>
