---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import PartyLookbook from "../components/content/PartyLookbook.astro";
import {
  lookbookCategoryFilters,
  lookbookHero,
  lookbookItems,
  lookbookServiceFilters,
  lookbookSpeedFilters,
} from "../data/lookbook";

const canonicalPath = "/gallery/";
---

<BaseLayout
  title="Face Painting, Balloon Twisting & Glitter Tattoo Gallery | Happy Faces LA"
  description="Browse face painting, balloon twisting, glitter tattoo, and face gem event photos from Happy Faces LA in Los Angeles."
  canonicalPath={canonicalPath}
>
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Gallery", href: canonicalPath },
    ]}
  />
  <PartyLookbook
    items={lookbookItems}
    serviceFilters={lookbookServiceFilters}
    speedFilters={lookbookSpeedFilters}
    categoryFilters={lookbookCategoryFilters}
    hero={lookbookHero}
  />

  <section class="mx-auto w-full max-w-6xl px-4 pb-10">
    <p class="max-w-3xl text-sm leading-relaxed text-slate-700">
      After browsing recent party looks, you can
      <a class="font-semibold text-orange-600 hover:text-orange-700" href="/reviews/">see customer reviews</a>
      or compare
      <a class="font-semibold text-orange-600 hover:text-orange-700" href="/face-painting-cost-los-angeles/">face painting cost and party package examples</a>
      before requesting availability.
    </p>
  </section>
</BaseLayout>
