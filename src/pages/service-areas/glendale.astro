---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import PageIntro from "../../components/sections/PageIntro.astro";
import LocationPageSections from "../../components/sections/LocationPageSections.astro";
import { priorityLocations } from "../../data/locations";

const location = priorityLocations.find((item) => item.slug === "glendale")!;
const canonicalPath = "/service-areas/glendale/";
---

<BaseLayout title="Face Painting in Glendale | Happy Faces LA" description="Book Happy Faces LA for face painting, balloons, glitter tattoos, and face gems in Glendale." canonicalPath={canonicalPath} noindex={true}>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Service Areas", href: "/service-areas/" }, { label: "Glendale", href: canonicalPath }]} />
  <PageIntro title="Face Painting, Balloon Twisting & Glitter Tattoos in Glendale" description="Happy Faces LA provides face painting, balloon twisting, glitter tattoos, and face jewelry for birthdays, school events, and private celebrations in Glendale." />
  <LocationPageSections location={location} />
</BaseLayout>
