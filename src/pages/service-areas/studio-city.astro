---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import PageIntro from "../../components/sections/PageIntro.astro";
import LocationPageSections from "../../components/sections/LocationPageSections.astro";
import { priorityLocations } from "../../data/locations";

const location = priorityLocations.find((item) => item.slug === "studio-city")!;
const canonicalPath = "/service-areas/studio-city/";
---

<BaseLayout title="Face Painting in Studio City | Happy Faces LA" description="Book Happy Faces LA for face painting, balloons, glitter tattoos, and face gems in Studio City." canonicalPath={canonicalPath}>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Service Areas", href: "/service-areas/" }, { label: "Studio City", href: canonicalPath }]} />
  <PageIntro title="Face Painting, Balloon Twisting & Glitter Tattoos in Studio City" description="Happy Faces LA provides face painting, balloon twisting, glitter tattoos, and face jewelry for birthdays, school events, and private celebrations in Studio City." />
  <LocationPageSections location={location} />
</BaseLayout>
