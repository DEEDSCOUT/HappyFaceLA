---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import PageIntro from "../../components/sections/PageIntro.astro";
import { priorityLocations } from "../../data/locations";

const canonicalPath = "/service-areas/";
const serviceFaqs = [
  {
    question: "Which areas does Happy Faces LA serve?",
    answer:
      "Serving children's parties and family events across Los Angeles County, Orange County and Ventura County. Share your event city or ZIP code to confirm availability.",
  },
  {
    question: "What services can we request?",
    answer:
      "Families can request face painting, balloon twisting, glitter tattoos, face gems, and kids birthday entertainment based on event details and availability.",
  },
  {
    question: "How do we confirm availability for our event?",
    answer:
      "Share your event date, city or ZIP code, and requested services. Happy Faces LA confirms availability and next steps in writing.",
  },
];
---

<BaseLayout
  title="Service Areas | Happy Faces LA"
  description="Serving children's parties and family events across Los Angeles County, Orange County and Ventura County. Share your event city or ZIP code to confirm availability."
  canonicalPath={canonicalPath}
  noindex={true}
>
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Service Areas", href: canonicalPath },
    ]}
  />
  <PageIntro
    title="Tri-County Service Areas"
    description="Serving children's parties and family events across Los Angeles County, Orange County and Ventura County. Share your event city or ZIP code to confirm availability."
  />

  <section class="mx-auto w-full max-w-6xl px-4 py-10">
    <article class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">
        Tri-county service-area overview
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        Happy Faces LA provides family-focused event entertainment across Los
        Angeles County, Orange County and Ventura County. Availability is
        confirmed per event request using your city or ZIP code, event date and
        requested services.
      </p>
    </article>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h3 class="text-lg font-semibold text-slate-900">Los Angeles County</h3>
        <p class="mt-2 text-sm text-slate-700">
          Los Angeles County events remain a core service area for birthdays and
          family events. For city-level details, review available local pages
          and request confirmation by city or ZIP code.
        </p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h3 class="text-lg font-semibold text-slate-900">Orange County</h3>
        <p class="mt-2 text-sm text-slate-700">
          Orange County requests are reviewed by date, location and service mix.
          Availability is confirmed for each event after city or ZIP code
          review.
        </p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h3 class="text-lg font-semibold text-slate-900">Ventura County</h3>
        <p class="mt-2 text-sm text-slate-700">
          Ventura County requests are also supported on an
          availability-confirmed basis. Share event details so Happy Faces LA
          can confirm next steps.
        </p>
      </article>
    </div>

    <article class="mt-8 rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">
        Services families can request
      </h2>
      <ul class="mt-4 space-y-2 text-sm text-slate-700">
        <li>Face painting</li>
        <li>Balloon twisting</li>
        <li>Glitter tattoos</li>
        <li>Face gems</li>
        <li>Kids birthday entertainment and family events</li>
      </ul>
    </article>

    <article class="mt-8 rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">
        Availability confirmation
      </h2>
      <p class="mt-3 text-sm text-slate-700">
        Serving children's parties and family events across Los Angeles County,
        Orange County and Ventura County. Share your event city or ZIP code to
        confirm availability.
      </p>
      <p class="mt-2 text-sm text-slate-700">
        Include your event date and requested services to receive an
        availability response and next steps.
      </p>
    </article>

    <article class="mt-8 rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">
        Explore services and planning resources
      </h2>
      <div class="mt-4 grid gap-2 text-sm">
        <a class="text-orange-600 hover:underline" href="/services/"
          >All services</a
        >
        <a class="text-orange-600 hover:underline" href="/pricing/">Pricing</a>
        <a class="text-orange-600 hover:underline" href="/gallery/">Gallery</a>
        <a
          class="text-orange-600 hover:underline"
          href="/kids-birthday-party-entertainment-los-angeles/"
          >Kids birthday entertainment</a
        >
        <a
          class="text-orange-600 hover:underline"
          href="/face-painting-los-angeles/">Face painting</a
        >
        <a
          class="text-orange-600 hover:underline"
          href="/balloon-twisting-los-angeles/">Balloon twisting</a
        >
        <a
          class="text-orange-600 hover:underline"
          href="/glitter-tattoos-los-angeles/">Glitter tattoos</a
        >
        <a
          class="text-orange-600 hover:underline"
          href="/face-gems-face-jewelry-los-angeles/">Face gems</a
        >
        <a class="text-orange-600 hover:underline" href="/contact/"
          >Request availability</a
        >
      </div>
    </article>

    <article class="mt-8 rounded-2xl border border-orange-200 bg-orange-50 p-6">
      <h2 class="text-2xl font-bold text-orange-900">Request a quote</h2>
      <p class="mt-3 text-sm text-orange-900">
        Share your event date, city or ZIP code and requested services. Happy
        Faces LA will confirm availability and next steps.
      </p>
      <a
        class="mt-4 inline-block rounded-xl bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600"
        href="/contact/"
      >
        Get availability and quote details
      </a>
    </article>

    <article class="mt-8 rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">
        Frequently asked questions
      </h2>
      <div class="mt-4 space-y-4">
        {
          serviceFaqs.map((faq) => (
            <div class="rounded-xl border border-slate-200 p-4">
              <h3 class="text-base font-semibold text-slate-900">
                {faq.question}
              </h3>
              <p class="mt-2 text-sm text-slate-700">{faq.answer}</p>
            </div>
          ))
        }
      </div>
    </article>

    <div class="mt-8">
      <h2 class="text-xl font-semibold text-slate-900">Current city pages</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          priorityLocations.map((location) => (
            <a
              class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-orange-400"
              href={`/service-areas/${location.slug}/`}
            >
              <h3 class="text-lg font-semibold text-slate-900">
                {location.city}
              </h3>
              <p class="mt-2 text-sm text-slate-600">
                Face painting, balloons, glitter tattoos, and face gems for
                events in {location.city}.
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
