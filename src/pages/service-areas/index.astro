---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import PageIntro from "../../components/sections/PageIntro.astro";
import { priorityLocations } from "../../data/locations";

const canonicalPath = "/service-areas/";
---

<BaseLayout
  title="Service Areas | Happy Faces LA"
  description="Explore service areas for Happy Faces LA across Los Angeles and nearby cities."
  canonicalPath={canonicalPath}
  noindex={true}
>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Service Areas", href: canonicalPath }]} />
  <PageIntro title="Service Areas" description="Happy Faces LA serves Los Angeles and nearby LA-area cities. Select a city page for local details." />

  <section class="mx-auto w-full max-w-6xl px-4 py-10">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {priorityLocations.map((location) => (
        <a class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-orange-400" href={`/service-areas/${location.slug}/`}>
          <h2 class="text-xl font-semibold text-slate-900">{location.city}</h2>
          <p class="mt-2 text-sm text-slate-600">Face painting, balloons, glitter tattoos, and face gems for events in {location.city}.</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
