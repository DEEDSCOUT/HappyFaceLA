---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import ServiceCrossSell from "../components/sections/ServiceCrossSell.astro";
import ServiceAreaLinks from "../components/sections/ServiceAreaLinks.astro";
import FAQAccordion from "../components/content/FAQAccordion.astro";
import BookingCtaBlock from "../components/sections/BookingCtaBlock.astro";
import { commonFaqs } from "../data/faqs";
import { breadcrumbJsonLd, localBusinessJsonLd } from "../utils/schema";

const canonicalPath = "/services/";
---

<BaseLayout
  title="Kids Party Entertainment Los Angeles | Face Painting, Balloons, Glitter Tattoos"
  description="Book Happy Faces LA for face painting, balloon twisting, glitter tattoos, and face gems for birthdays, school events, festivals, and private parties across Los Angeles."
  canonicalPath={canonicalPath}
  jsonLd={[
    localBusinessJsonLd(),
    breadcrumbJsonLd([
      { name: "Home", url: "https://happyfacesla.com/" },
      { name: "Services", url: `https://happyfacesla.com${canonicalPath}` },
    ]),
  ]}
>
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Services", href: canonicalPath },
    ]}
  />

  <section
    class="relative overflow-hidden bg-gradient-to-br from-amber-50 via-white to-cyan-50"
  >
    <div
      class="absolute -left-16 top-8 h-52 w-52 rounded-full bg-orange-200/50 blur-2xl"
    >
    </div>
    <div
      class="absolute -right-16 bottom-0 h-64 w-64 rounded-full bg-cyan-200/50 blur-2xl"
    >
    </div>

    <div class="relative mx-auto w-full max-w-6xl px-4 py-14 md:py-20">
      <h1
        class="text-4xl font-extrabold leading-tight text-slate-900 md:text-5xl lg:text-6xl"
      >
        Face Painting, Balloon Twisting, Glitter Tattoos &amp; Face Gems in Los
        Angeles
      </h1>
      <p class="mt-5 max-w-3xl text-lg text-slate-700">
        Happy Faces LA brings colorful, kid-friendly party entertainment to
        birthdays, school events, festivals, community events, and family
        celebrations. Serving Los Angeles and nearby areas. Share your event
        city or ZIP code for availability.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a
          class="rounded-xl bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600"
          href="/plan-my-party/"
        >
          Plan My Party
        </a>
        <a
          class="rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-900"
          href="tel:+18186195506"
          data-track-event="phone_click"
        >
          Call/Text 818-619-5506
        </a>
      </div>
      <p class="mt-5 text-sm text-slate-600">
        Face painting • Balloon twisting • Glitter tattoos • Face gems •
        Combined services
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 py-12">
    <h2 class="text-2xl font-bold text-slate-900">Our services</h2>
    <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-700">
      Pick a single service or combine two or more to keep guests engaged across
      the whole event. Each service can be booked alone or bundled into a custom
      package.
    </p>
    <div class="mt-6">
      <ServiceCrossSell
        title="Choose a service to learn more"
        description="Each page includes what is included, who it is best for, and how it pairs with other services. When you are ready, use Plan My Party as the single planning path for any combination."
        showCta={false}
      />
    </div>
    <p class="mt-6 text-sm text-slate-700">
      <a
        class="text-orange-600 hover:underline"
        href="/kids-birthday-party-entertainment-los-angeles/"
        >Planning a birthday party? Explore kids birthday party face painting
        and entertainment in Los Angeles →</a
      >
    </p>
    <p class="mt-3 text-sm text-slate-700">
      <a
        class="text-orange-600 hover:underline"
        href="/face-painting-cost-los-angeles/"
        >See face painting and party pricing examples, package options, and Los
        Angeles travel fees in our cost guide →</a
      >
    </p>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-12">
    <div class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">More ways to shape the party</h2>
      <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-700">
        Tell us the mood you want, and we can shape the core Happy Faces LA services around it.
        These ideas work well for kids and adults together, so parents can enjoy the celebration
        instead of managing every activity.
      </p>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <h3 class="text-base font-semibold text-slate-900">Bright, high-energy themes</h3>
          <p class="mt-1 text-sm leading-relaxed text-slate-700">
            Neon arcade colors, space-inspired designs, glitter accents, and fast fan looks can make
            a station feel active and photo-ready.
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <h3 class="text-base font-semibold text-slate-900">Calmer creative corners</h3>
          <p class="mt-1 text-sm leading-relaxed text-slate-700">
            Eco-friendly craft styling, sensory-friendly pacing, and gentler design menus can help
            mixed-age parties feel easier for families.
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <h3 class="text-base font-semibold text-slate-900">All-ages interaction</h3>
          <p class="mt-1 text-sm leading-relaxed text-slate-700">
            Face painting, balloons, glitter, and gems can invite adults and children into the same
            activity, creating a shared moment instead of a kids-only station.
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <h3 class="text-base font-semibold text-slate-900">Add-on ideas to discuss</h3>
          <p class="mt-1 text-sm leading-relaxed text-slate-700">
            Bubble play, craft stations, themed photo moments, and wellness-inspired quiet corners can
            be discussed during planning when they fit the event.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-12">
    <ServiceAreaLinks />
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-12">
    <FAQAccordion items={commonFaqs} />
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-14">
    <BookingCtaBlock />
  </section>
</BaseLayout>
