---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import ServicePageSections from "../components/sections/ServicePageSections.astro";
import { services } from "../data/services";
import { facePaintingFaqs } from "../data/faqs";
import { serviceJsonLd, breadcrumbJsonLd, localBusinessJsonLd, faqJsonLd } from "../utils/schema";

const service = services.find((item) => item.slug === "face-painting-los-angeles")!;
const canonicalPath = "/face-painting-los-angeles/";
---

<BaseLayout
  title="Face Painting Los Angeles | Kids Birthday Parties & Events"
  description="Professional face painting for birthdays, school events, festivals, and private celebrations in Los Angeles. Bundle with balloon twisting, glitter tattoos, and face gems."
  canonicalPath={canonicalPath}
  jsonLd={[
    localBusinessJsonLd(),
    serviceJsonLd(service.name, `https://happyfacesla.com${canonicalPath}`),
    breadcrumbJsonLd([
      { name: "Home", url: "https://happyfacesla.com/" },
      { name: "Face Painting in Los Angeles", url: `https://happyfacesla.com${canonicalPath}` }
    ]),
    faqJsonLd(facePaintingFaqs)
  ]}
>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Face Painting", href: canonicalPath }]} />
  <PageIntro
    title="Face Painting in Los Angeles"
    description={service.heroSubcopy ?? service.description}
    showCtas={true}
    trustLine="Often booked with balloon twisting, glitter tattoos, or face gems."
  />
  <ServicePageSections service={service} faqs={facePaintingFaqs} />
</BaseLayout>
