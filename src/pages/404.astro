---
import BaseLayout from "../layouts/BaseLayout.astro";

const canonicalPath = "/404/";
---

<BaseLayout
  title="Page Not Found | Happy Faces LA"
  description="The page you requested was not found."
  canonicalPath={canonicalPath}
  jsonLd={[]}
>
  <section class="mx-auto w-full max-w-4xl px-4 py-20 text-center">
    <h1 class="text-5xl font-extrabold text-slate-900">404</h1>
    <p class="mt-4 text-lg text-slate-700">That page is not available.</p>
    <a class="mt-6 inline-block rounded-xl bg-orange-500 px-5 py-3 text-sm font-semibold text-white" href="/">
      Back to Homepage
    </a>
  </section>
</BaseLayout>
