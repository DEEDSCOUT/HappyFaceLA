// Conservative, parent-safe trust notes shown under the hero.
const trustNotes = [
  "Fast party station",
  "Great for older kids and teens",
  "Pairs with face painting, balloons, or face gems",
  "Los Angeles kids party entertainment",
];

const applySteps = [
  "Skin area is prepared or lightly cleaned.",
  "Child chooses a design.",
  "Stencil is placed.",
  "Cosmetic adhesive is applied.",
  "Glitter is pressed onto the adhesive.",
  "Excess glitter is brushed away.",
  "Stencil is removed to reveal the final design.",
];

const eventTypes = [
  {
    title: "Birthday parties",
    copy: "A sparkly station and a wearable party favor kids keep for days after the celebration.",
  },
  {
    title: "School festivals and fundraisers",
    copy: "Quick application keeps booth lines moving, which works well for carnivals and PTA events.",
  },
  {
    title: "Corporate family days",
    copy: "A kid-friendly activity that keeps children happy while parents socialize.",
  },
  {
    title: "Community events",
    copy: "A crowd favorite at street fairs and seasonal celebrations that appeals to a wide age range.",
  },
  {
    title: "Themed parties",
    copy: "Designs can echo a party theme, from fairy-style to ocean-themed and jungle-themed looks.",
  },
  {
    title: "Holiday events",
    copy: "Holiday-themed designs add a festive, photo-ready touch to seasonal gatherings.",
  },
  {
    title: "Older kids and teen-friendly parties",
    copy: "A polished, sparkle-forward option for guests who may feel too old for full-face painting.",
  },
];

const designCategories = [
  "Butterflies",
  "Hearts",
  "Stars",
  "Unicorns",
  "Animals",
  "Flowers",
  "Fairy-style designs",
  "Princess-inspired designs",
  "Superhero-inspired shapes",
  "Sports-inspired designs",
  "Team-color inspired designs",
  "Holiday and themed party designs",
];

const parentChecklist = [
  "Share the child age range.",
  "Share approximate guest count.",
  "Mention sensitive skin, allergies, or skin concerns.",
  "Confirm indoor or outdoor setup.",
  "Provide shade for outdoor events.",
  "Provide a clean, stable working area.",
  "Confirm whether glitter tattoos are standalone or paired with other services.",
  "Ask about realistic coverage for the available time.",
  "Confirm parking/access notes if relevant.",
];

const bookingSteps = [
  "Submit event date, city/ZIP, guest count, age range, and requested services through Plan My Party.",
  "Happy Faces LA reviews availability, service mix, guest count, travel, and setup needs.",
  "Happy Faces LA follows up with the recommended setup and pricing.",
  "Booking is not confirmed until availability is confirmed and the final booking steps are completed.",
];

// One FAQ array drives both the visible accordion and the FAQPage schema,
// so the structured data always matches the on-page content exactly.
const faqs: FaqItem[] = [
  {
    question: "What are glitter tattoos?",
    answer:
      "Glitter tattoos are temporary, sparkly body-art designs applied with a stencil, skin-safe cosmetic adhesive, and cosmetic glitter. They sit on top of the skin, do not use needles, and usually fade gradually over several days depending on activity, bathing, skin type, and aftercare.",
  },
  {
    question: "How long do glitter tattoos last?",
