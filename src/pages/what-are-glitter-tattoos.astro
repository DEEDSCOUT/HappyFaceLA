---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import FAQAccordion from "../components/content/FAQAccordion.astro";
import BookingCtaBlock from "../components/sections/BookingCtaBlock.astro";
import type { FaqItem } from "../data/faqs";
import { business } from "../data/business";
import {
  localBusinessJsonLd,
  breadcrumbJsonLd,
  faqJsonLd,
  articleJsonLd,
} from "../utils/schema";

const phoneCtaLabel = `Call/Text ${business.displayPhone}`;
const phoneTelHref = `tel:${business.phone.replace(/^\+1/, "")}`;

