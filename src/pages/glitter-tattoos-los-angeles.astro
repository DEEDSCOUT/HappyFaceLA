---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import ServicePageSections from "../components/sections/ServicePageSections.astro";
import { services } from "../data/services";
import { glitterTattooFaqs } from "../data/faqs";
import {
  serviceJsonLd,
  breadcrumbJsonLd,
  localBusinessJsonLd,
  faqJsonLd,
} from "../utils/schema";

const service = services.find(
  (item) => item.slug === "glitter-tattoos-los-angeles",
)!;
const canonicalPath = "/glitter-tattoos-los-angeles/";
---

<BaseLayout
  title="Glitter Tattoos Los Angeles | Birthday Party Glitter Tattoo Artist"
  description="Glitter tattoo designs for kids birthday parties in Los Angeles. Pairs with face painting, face gems, and balloon twisting. Book through Happy Faces LA."
  canonicalPath={canonicalPath}
  jsonLd={[
    localBusinessJsonLd(),
    serviceJsonLd(service.name, `https://happyfacesla.com${canonicalPath}`),
    breadcrumbJsonLd([
      { name: "Home", url: "https://happyfacesla.com/" },
      {
        name: "Glitter Tattoos in Los Angeles",
        url: `https://happyfacesla.com${canonicalPath}`,
      },
    ]),
    faqJsonLd(glitterTattooFaqs),
  ]}
>
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Glitter Tattoos", href: canonicalPath },
    ]}
  />
  <PageIntro
    title="Glitter Tattoos in Los Angeles"
    description={service.heroSubcopy ?? service.description}
    showCtas={true}
    trustLine="A fast station — great alongside face painting, balloon twisting, or face gems."
  />
  <section class="mx-auto w-full max-w-6xl px-4 pt-6">
    <p class="text-sm text-slate-600">
      Wondering about pricing? Our
      <a
        href="/face-painting-cost-los-angeles/"
        class="text-orange-600 hover:underline"
        >party cost guide</a
      > breaks down package options, two-service mixes that include glitter
      tattoos, and travel fees for Los Angeles events.
    </p>
  </section>
  <ServicePageSections service={service} faqs={glitterTattooFaqs} />
</BaseLayout>
