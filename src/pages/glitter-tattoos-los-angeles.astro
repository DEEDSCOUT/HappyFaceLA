---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import ServicePageSections from "../components/sections/ServicePageSections.astro";
import { services } from "../data/services";
import { glitterTattooFaqs } from "../data/faqs";
import { serviceJsonLd, breadcrumbJsonLd, localBusinessJsonLd, faqJsonLd } from "../utils/schema";

const service = services.find((item) => item.slug === "glitter-tattoos-los-angeles")!;
const canonicalPath = "/glitter-tattoos-los-angeles/";
---

<BaseLayout
  title="Glitter Tattoos Los Angeles | Kids Party Glitter Tattoos"
  description="Cosmetic-grade glitter tattoos for kids parties, school carnivals, and festivals in Los Angeles. Lasts 1–3 days. Pairs with face painting and face gems."
  canonicalPath={canonicalPath}
  jsonLd={[
    localBusinessJsonLd(),
    serviceJsonLd(service.name, `https://happyfacesla.com${canonicalPath}`),
    breadcrumbJsonLd([
      { name: "Home", url: "https://happyfacesla.com/" },
      { name: "Glitter Tattoos in Los Angeles", url: `https://happyfacesla.com${canonicalPath}` }
    ]),
    faqJsonLd(glitterTattooFaqs)
  ]}
>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Glitter Tattoos", href: canonicalPath }]} />
  <PageIntro
    title="Glitter Tattoos in Los Angeles"
    description={service.heroSubcopy ?? service.description}
    showCtas={true}
    trustLine="A fast station — great alongside face painting, balloon twisting, or face gems."
  />
  <ServicePageSections service={service} faqs={glitterTattooFaqs} />
</BaseLayout>
