---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import GoogleReviewsSection from "../components/sections/GoogleReviewsSection.astro";

const canonicalPath = "/reviews/";
---

<BaseLayout
  title="Happy Faces LA Reviews | Face Painting & Kids Party Entertainment"
  description="Read real feedback from families and event hosts who booked Happy Faces LA for face painting, balloon twisting, glitter tattoos, face gems, and kids party entertainment in Los Angeles."
  canonicalPath={canonicalPath}
>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Reviews", href: canonicalPath }]} />
  <PageIntro
    title="Happy Faces LA Reviews"
    description="Read real feedback from families and event hosts who booked Happy Faces LA for face painting, balloon twisting, glitter tattoos, face gems, and kids party entertainment in Los Angeles."
  />

  <section class="mx-auto w-full max-w-4xl px-4 pb-2">
    <p class="text-base leading-relaxed text-slate-700">
      Reviews on this page include feedback from the Happy Faces LA Google Business Profile and direct event feedback shared after real bookings.
    </p>
  </section>

  <GoogleReviewsSection heading="Latest Google reviews" />
  <TestimonialsSection />

  <section class="mx-auto w-full max-w-4xl px-4 pb-10">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 text-sm leading-relaxed text-slate-700">
      <p>After your event, we may ask for an honest review so other families can learn what to expect. Reviews are never invented, edited to mislead, or used with fake customer identities.</p>
    </div>
  </section>
</BaseLayout>
