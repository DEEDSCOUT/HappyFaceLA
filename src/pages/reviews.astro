---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import PageIntro from "../components/sections/PageIntro.astro";

const canonicalPath = "/reviews/";
---

<BaseLayout
  title="Reviews | Happy Faces LA"
  description="Read verified Happy Faces LA customer reviews and event feedback for face painting, balloon twisting, glitter tattoos, face gems, and kids party entertainment."
  canonicalPath={canonicalPath}
>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Reviews", href: canonicalPath }]} />
  <PageIntro title="Reviews" description="Real customer reviews are being added as Happy Faces LA collects verified feedback from events." />

  <section class="mx-auto w-full max-w-4xl px-4 py-10">
    <div class="space-y-4 rounded-2xl border border-slate-200 bg-white p-6 text-sm leading-relaxed text-slate-700">
      <p>Real customer reviews are being added as Happy Faces LA collects verified feedback from events.</p>
      <p>After your event, we may ask for an honest review so other families can learn what to expect. Reviews are never invented, edited to mislead, or used with fake customer identities.</p>
    </div>
  </section>
</BaseLayout>
