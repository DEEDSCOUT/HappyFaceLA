---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import ServicePageSections from "../components/sections/ServicePageSections.astro";
import { services } from "../data/services";
import { commonFaqs } from "../data/faqs";
import { serviceJsonLd, breadcrumbJsonLd, localBusinessJsonLd, faqJsonLd } from "../utils/schema";

const service = services.find((item) => item.slug === "balloon-twisting-los-angeles")!;
const canonicalPath = "/balloon-twisting-los-angeles/";
---

<BaseLayout
  title="Balloon Twisting in Los Angeles | Happy Faces LA"
  description="Book Happy Faces LA for balloon twisting in Los Angeles for birthdays, school events, and festivals. Call/text 818-619-5506."
  canonicalPath={canonicalPath}
  jsonLd={[
    localBusinessJsonLd(),
    serviceJsonLd(service.name, `https://happyfacesla.com${canonicalPath}`),
    breadcrumbJsonLd([
      { name: "Home", url: "https://happyfacesla.com/" },
      { name: "Balloon Twisting in Los Angeles", url: `https://happyfacesla.com${canonicalPath}` }
    ]),
    faqJsonLd(commonFaqs)
  ]}
>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Balloon Twisting", href: canonicalPath }]} />
  <PageIntro title="Balloon Twisting in Los Angeles" description={service.description} />
  <ServicePageSections service={service} faqs={commonFaqs} />
</BaseLayout>
