---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import ServicePageSections from "../components/sections/ServicePageSections.astro";
import { services } from "../data/services";
import { balloonTwistingFaqs } from "../data/faqs";
import {
  serviceJsonLd,
  breadcrumbJsonLd,
  localBusinessJsonLd,
  faqJsonLd,
} from "../utils/schema";

const service = services.find(
  (item) => item.slug === "balloon-twisting-los-angeles",
)!;
const canonicalPath = "/balloon-twisting-los-angeles/";
---

<BaseLayout
  title="Balloon Twisting Los Angeles | Birthday Party Balloon Artist"
  description="Book Happy Faces LA for balloon twisting at birthday parties in Los Angeles. Pairs with face painting, glitter tattoos, and face gems."
  canonicalPath={canonicalPath}
  jsonLd={[
    localBusinessJsonLd(),
    serviceJsonLd(service.name, `https://happyfacesla.com${canonicalPath}`),
    breadcrumbJsonLd([
      { name: "Home", url: "https://happyfacesla.com/" },
      {
        name: "Balloon Twisting in Los Angeles",
        url: `https://happyfacesla.com${canonicalPath}`,
      },
    ]),
    faqJsonLd(balloonTwistingFaqs),
  ]}
>
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Balloon Twisting", href: canonicalPath },
    ]}
  />
  <PageIntro
    title="Balloon Twisting in Los Angeles"
    description={service.heroSubcopy ?? service.description}
    showCtas={true}
    trustLine="Often paired with face painting, glitter tattoos, or face gems."
  />
  <section class="mx-auto w-full max-w-6xl px-4 pt-6">
    <p class="text-sm text-slate-600">
      Planning your party budget? Our
      <a
        href="/face-painting-cost-los-angeles/"
        class="text-orange-600 hover:underline"
        >face painting and party cost guide</a
      > covers package examples, two-service party mixes, add-ons, and Los
      Angeles travel fees.
    </p>
  </section>
  <ServicePageSections service={service} faqs={balloonTwistingFaqs} />
</BaseLayout>
