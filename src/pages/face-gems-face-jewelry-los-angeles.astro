---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import ServicePageSections from "../components/sections/ServicePageSections.astro";
import { services } from "../data/services";
import { commonFaqs } from "../data/faqs";
import { serviceJsonLd, breadcrumbJsonLd, localBusinessJsonLd, faqJsonLd } from "../utils/schema";

const service = services.find((item) => item.slug === "face-gems-face-jewelry-los-angeles")!;
const canonicalPath = "/face-gems-face-jewelry-los-angeles/";
---

<BaseLayout
  title="Face Gems Los Angeles | Kids Party Face Gems & Festival Looks"
  description="Crystal-like face gems and face jewelry for themed birthday parties, princess events, and photo moments in Los Angeles. Booked alone or paired with face painting and glitter tattoos."
  canonicalPath={canonicalPath}
  jsonLd={[
    localBusinessJsonLd(),
    serviceJsonLd(service.name, `https://happyfacesla.com${canonicalPath}`),
    breadcrumbJsonLd([
      { name: "Home", url: "https://happyfacesla.com/" },
      { name: "Face Gems & Face Jewelry in Los Angeles", url: `https://happyfacesla.com${canonicalPath}` }
    ]),
    faqJsonLd(commonFaqs)
  ]}
>
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Face Gems & Face Jewelry", href: canonicalPath }]} />
  <PageIntro
    title="Face Gems & Face Jewelry in Los Angeles"
    description={service.heroSubcopy ?? service.description}
    showCtas={true}
    trustLine="Beautiful as a finishing touch on face painting or glitter tattoos."
  />
  <ServicePageSections service={service} faqs={commonFaqs} />
</BaseLayout>
