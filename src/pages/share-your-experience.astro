---
import BaseLayout from "../layouts/BaseLayout.astro";

const canonicalPath = "/share-your-experience/";

const serviceOptions = [
  { value: "face-painting", label: "Face Painting" },
  { value: "balloon-twisting", label: "Balloon Twisting" },
  { value: "glitter-tattoos", label: "Glitter Tattoos" },
  { value: "face-gems", label: "Face Gems / Face Jewelry" },
];

const eventTypeOptions = [
  "Kids Birthday Party",
  "Corporate Event",
  "School / Festival",
  "Private Party",
  "Wedding",
  "Other",
];
---

<BaseLayout
  title="Share Your Experience | Happy Faces LA"
  description="Tell us about your experience with Happy Faces LA. Your feedback helps us improve and may appear on our website with your permission."
  canonicalPath={canonicalPath}
  noindex={true}
>
  <section class="mx-auto w-full max-w-2xl px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">Share Your Experience</h1>
      <p class="mt-3 text-base text-slate-600">
        Thank you for choosing Happy Faces LA! Fill in the form below to share how your event went.
        All submissions are reviewed before anything is published publicly.
      </p>
    </div>

    <!-- Success state (hidden by default) -->
    <div
      id="testimonial-success"
      class="hidden rounded-xl border border-green-200 bg-green-50 px-6 py-8 text-center"
      role="status"
      aria-live="polite"
    >
      <p class="text-lg font-semibold text-green-800">Thank you! Your feedback has been received.</p>
      <p class="mt-2 text-sm text-green-700">
        If approved, it may appear on our website. We may reach out to verify your submission.
      </p>
    </div>

    <!-- Error banner (hidden by default) -->
    <div
      id="testimonial-error"
      class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-4 text-sm text-red-700"
      role="alert"
      aria-live="assertive"
    >
      <p id="testimonial-error-msg">Something went wrong. Please try again in a moment.</p>
    </div>

    <form
      id="testimonial-form"
      novalidate
      class="mt-6 space-y-6"
      data-testimonial-form
    >
      <!-- Honeypot — hidden from real users, traps automated bots -->
      <div class="hidden" aria-hidden="true">
        <label for="t-website">Website</label>
        <input id="t-website" name="honeypot" type="text" tabindex="-1" autocomplete="off" />
      </div>

      <!-- Name row -->
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="sm:col-span-2">
          <label for="t-first-name" class="block text-sm font-medium text-slate-700">
            First Name <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            id="t-first-name"
            name="first_name"
            type="text"
            required
            autocomplete="given-name"
            class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 placeholder-slate-400 shadow-sm focus:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-300"
            placeholder="e.g. Maria"
          />
          <p class="mt-1 hidden text-xs text-red-600" data-error="first_name"></p>
        </div>

        <div>
          <label for="t-last-initial" class="block text-sm font-medium text-slate-700">
            Last Initial <span class="text-slate-400 font-normal">(optional)</span>
          </label>
          <input
            id="t-last-initial"
            name="last_initial"
            type="text"
            maxlength="1"
            autocomplete="family-name"
            class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 placeholder-slate-400 shadow-sm focus:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-300"
            placeholder="e.g. S"
          />
        </div>
      </div>

      <!-- City / Area -->
      <div>
        <label for="t-city" class="block text-sm font-medium text-slate-700">
          City or Area <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <input
          id="t-city"
          name="city_or_area"
          type="text"
          required
          autocomplete="address-level2"
          class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 placeholder-slate-400 shadow-sm focus:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-300"
          placeholder="e.g. Pasadena, Glendale, the Valley…"
        />
        <p class="mt-1 hidden text-xs text-red-600" data-error="city_or_area"></p>
      </div>

      <!-- Event type -->
      <div>
        <label for="t-event-type" class="block text-sm font-medium text-slate-700">
          Type of Event <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <select
          id="t-event-type"
          name="event_type"
          required
          class="mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-300"
        >
          <option value="" disabled selected>Select your event type…</option>
          {eventTypeOptions.map((opt) => (
            <option value={opt}>{opt}</option>
          ))}
        </select>
        <p class="mt-1 hidden text-xs text-red-600" data-error="event_type"></p>
      </div>

      <!-- Services booked -->
      <fieldset>
        <legend class="block text-sm font-medium text-slate-700">
          Services Booked <span class="text-red-500" aria-hidden="true">*</span>
        </legend>
        <p class="mt-1 text-xs text-slate-500">Select all that apply.</p>
        <div class="mt-2 grid grid-cols-1 gap-2 sm:grid-cols-2">
          {serviceOptions.map(({ value, label }) => (
            <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 hover:bg-pink-50">
              <input
                type="checkbox"
                name="services_booked"
                value={value}
                class="h-4 w-4 rounded border-slate-300 text-pink-500 accent-pink-500 focus:ring-pink-300"
              />
              {label}
            </label>
          ))}
        </div>
        <p class="mt-1 hidden text-xs text-red-600" data-error="services_booked"></p>
      </fieldset>

      <!-- Testimonial text -->
      <div>
        <label for="t-testimonial" class="block text-sm font-medium text-slate-700">
          Your Experience <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <p class="mt-1 text-xs text-slate-500">
          Tell us what you enjoyed most. How did the kids react? Would you book again?
        </p>
        <textarea
          id="t-testimonial"
          name="testimonial_text"
          required
          rows={5}
          maxlength={2000}
          class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 placeholder-slate-400 shadow-sm focus:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-300"
          placeholder="e.g. The kids were absolutely mesmerized! Maria arrived on time and transformed…"
        ></textarea>
        <p class="mt-1 flex justify-between text-xs text-slate-400">
          <span id="t-char-count">0 / 2000 characters</span>
        </p>
        <p class="mt-1 hidden text-xs text-red-600" data-error="testimonial_text"></p>
      </div>

      <!-- Photo / video upload (optional — filename captured, no binary sent) -->
      <div>
        <label for="t-photo" class="block text-sm font-medium text-slate-700">
          Photo or Video <span class="text-slate-400 font-normal">(optional)</span>
        </label>
        <p class="mt-1 text-xs text-slate-500">
          Selecting a file here notes your intent to share media. We will follow up with you to
          collect the actual file. Photos are never published without your explicit approval.
        </p>
        <input
          id="t-photo"
          name="photo_file"
          type="file"
          accept="image/*,video/*"
          class="mt-1 block w-full text-sm text-slate-500 file:mr-3 file:cursor-pointer file:rounded-lg file:border-0 file:bg-pink-50 file:px-4 file:py-2 file:text-sm file:font-medium file:text-pink-700 hover:file:bg-pink-100"
        />
      </div>

      <!-- Contact for verification -->
      <div>
        <label for="t-contact" class="block text-sm font-medium text-slate-700">
          Email or Phone
          <span class="text-red-500" aria-hidden="true">*</span>
          <span class="ml-1 text-xs font-normal text-slate-500">— for verification only, never displayed publicly</span>
        </label>
        <input
          id="t-contact"
          name="contact_email_or_phone"
          type="text"
          required
          autocomplete="email"
          class="mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 placeholder-slate-400 shadow-sm focus:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-300"
          placeholder="your@email.com or (555) 555-5555"
        />
        <p class="mt-1 hidden text-xs text-red-600" data-error="contact_email_or_phone"></p>
      </div>

      <!-- Consent checkboxes -->
      <fieldset class="rounded-xl border border-slate-200 bg-slate-50 p-4 space-y-3">
        <legend class="text-sm font-semibold text-slate-700 px-1">
          Permissions <span class="text-red-500" aria-hidden="true">*</span>
        </legend>

        <label class="flex items-start gap-3 cursor-pointer">
          <input
            id="t-consent-publish"
            name="consent_to_publish"
            type="checkbox"
            required
            class="mt-0.5 h-4 w-4 shrink-0 rounded border-slate-300 text-pink-500 accent-pink-500 focus:ring-pink-300"
          />
          <span class="text-sm text-slate-700">
            I give Happy Faces LA permission to publish my testimonial on their website.
          </span>
        </label>
        <p class="ml-7 hidden text-xs text-red-600" data-error="consent_to_publish"></p>

        <label class="flex items-start gap-3 cursor-pointer">
          <input
            id="t-consent-details"
            name="consent_to_publish_details"
            type="checkbox"
            required
            class="mt-0.5 h-4 w-4 shrink-0 rounded border-slate-300 text-pink-500 accent-pink-500 focus:ring-pink-300"
          />
          <span class="text-sm text-slate-700">
            I consent to my first name, city/area, event type, and services booked being shown
            alongside my testimonial.
          </span>
        </label>
        <p class="ml-7 hidden text-xs text-red-600" data-error="consent_to_publish_details"></p>
      </fieldset>

      <button
        type="submit"
        id="testimonial-submit-btn"
        class="w-full rounded-xl bg-pink-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-pink-600 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:ring-offset-2 disabled:opacity-60"
      >
        Submit My Experience
      </button>
    </form>
  </section>
</BaseLayout>

<script is:inline>
(function () {
  var form = document.getElementById("testimonial-form");
  var successEl = document.getElementById("testimonial-success");
  var errorEl = document.getElementById("testimonial-error");
  var errorMsgEl = document.getElementById("testimonial-error-msg");
  var submitBtn = document.getElementById("testimonial-submit-btn");
  var textarea = document.getElementById("t-testimonial");
  var charCount = document.getElementById("t-char-count");

  // Live character counter for textarea
  if (textarea && charCount) {
    textarea.addEventListener("input", function () {
      var len = textarea.value.length;
      charCount.textContent = len + " / 2000 characters";
    });
  }

  function showFieldError(field, msg) {
    var el = document.querySelector("[data-error='" + field + "']");
    if (el) {
      el.textContent = msg;
      el.classList.remove("hidden");
    }
  }

  function clearFieldErrors() {
    var els = document.querySelectorAll("[data-error]");
    els.forEach(function (el) {
      el.textContent = "";
      el.classList.add("hidden");
    });
  }

  function showGlobalError(msg) {
    if (errorMsgEl) errorMsgEl.textContent = msg || "Something went wrong. Please try again.";
    if (errorEl) errorEl.classList.remove("hidden");
  }

  function hideGlobalError() {
    if (errorEl) errorEl.classList.add("hidden");
  }

  function trackEvent(name, params) {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: name, ...(params || {}) });
    if (typeof window.gtag === "function") {
      window.gtag("event", name, params || {});
    }
  }

  if (!form) return;

  form.addEventListener("submit", async function (e) {
    e.preventDefault();
    clearFieldErrors();
    hideGlobalError();

    var data = new FormData(form);

    // Collect services_booked array
    var servicesBooked = [];
    form.querySelectorAll("input[name='services_booked']:checked").forEach(function (cb) {
      servicesBooked.push(cb.value);
    });

    // Capture photo filename (binary is NOT sent — owner will follow up separately)
    var photoInput = document.getElementById("t-photo");
    var photoFilename = "";
    if (photoInput && photoInput.files && photoInput.files.length > 0) {
      photoFilename = photoInput.files[0].name;
    }

    var payload = {
      first_name: (data.get("first_name") || "").toString().trim(),
      last_initial: (data.get("last_initial") || "").toString().trim().slice(0, 1),
      city_or_area: (data.get("city_or_area") || "").toString().trim(),
      event_type: (data.get("event_type") || "").toString().trim(),
      services_booked: servicesBooked,
      testimonial_text: (data.get("testimonial_text") || "").toString().trim(),
      consent_to_publish: document.getElementById("t-consent-publish").checked,
      consent_to_publish_details: document.getElementById("t-consent-details").checked,
      contact_email_or_phone: (data.get("contact_email_or_phone") || "").toString().trim(),
      photo_filename: photoFilename,
      source_page: window.location.pathname,
      honeypot: (data.get("honeypot") || "").toString(),
    };

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending…";

    try {
      var res = await fetch("/api/testimonial", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });

      var json = await res.json();

      if (res.ok && json.ok) {
        form.classList.add("hidden");
        successEl.classList.remove("hidden");
        trackEvent("testimonial_form_submit", {
          event_type: payload.event_type,
          services_count: payload.services_booked.length,
        });
        return;
      }

      // Server returned validation errors
      if (json.errors) {
        Object.entries(json.errors).forEach(function ([field, msg]) {
          showFieldError(field, msg);
        });
        showGlobalError("Please correct the errors above and try again.");
      } else {
        showGlobalError(json.error || "Something went wrong. Please try again.");
      }
    } catch (err) {
      showGlobalError("Unable to submit. Please check your connection and try again.");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Submit My Experience";
    }
  });
})();
</script>
