---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import QuoteForm from "../components/conversion/QuoteForm.astro";
import { serviceJsonLd, faqJsonLd } from "../utils/schema";

const canonicalPath = "/pricing/";
const pricingFaqs = [
  {
    question: "Do you publish exact pricing online?",
    answer:
      "Pricing is provided in your personalized quote based on your event date, location, guest count, service mix, and number of artists needed. Package and add-on prices are confirmed by quote.",
  },
  {
    question: "What affects event pricing?",
    answer:
      "Date demand, travel, duration, add-ons, and staffing all affect final quote totals.",
  },
  {
    question: "How do Booking Retainers work?",
    answer:
      "A Booking Retainer of 20% of your approved booking total is required to confirm your event booking. Your event date is not reserved until the Booking Retainer is received.",
  },
];
---

<BaseLayout
  title="Pricing for Face Painting & Party Entertainment in Los Angeles | Happy Faces LA"
  description="Pricing depends on event date, location, guest count, and services requested. Request availability and pricing from Happy Faces LA."
  canonicalPath={canonicalPath}
  jsonLd={[
    serviceJsonLd(
      "Party Entertainment Pricing",
      `https://happyfacesla.com${canonicalPath}`,
    ),
    faqJsonLd(pricingFaqs),
  ]}
>
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Pricing", href: canonicalPath },
    ]}
  />
  <PageIntro
    title="Face Painting Pricing"
    description="Pricing is quote-first and depends on event date, location, number of guests, services requested, and artist count. Submit your event details for an accurate quote."
  />

  <section class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-10">
    <section class="rounded-2xl border border-orange-200 bg-orange-50 p-6">
      <h2 class="text-2xl font-bold text-slate-900">How pricing is confirmed</h2>
      <ol class="mt-4 space-y-2 text-sm text-slate-700">
        <li>1. Submit your event date, location, guest count, and services requested.</li>
        <li>2. Receive your personalized quote, including any applicable travel fee.</li>
        <li>3. Once your quote is approved, a Booking Retainer of 20% of your approved booking total is required to hold your date.</li>
        <li>4. Your event date is not reserved until the Booking Retainer is received.</li>
      </ol>
      <p class="mt-4 text-sm text-slate-700">
        There is no online payment or checkout at the quote submission stage.
      </p>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">What affects price</h2>
      <ul class="mt-4 space-y-2 text-sm text-slate-700">
        <li>Event date and time demand</li>
        <li>City and travel distance</li>
        <li>Guest count and service speed requirements</li>
        <li>Add-ons, extra artists, and overtime</li>
      </ul>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">Travel Fees</h2>
      <ul class="mt-4 space-y-2 text-sm text-slate-700">
        <li><strong>0–20 miles:</strong> No travel fee.</li>
        <li><strong>More than 20 through 40 miles:</strong> $25 flat travel fee.</li>
        <li><strong>More than 40 through 60 miles:</strong> $50 flat travel fee; manual booking approval is required.</li>
        <li><strong>More than 60 miles:</strong> Custom quote required; manual approval is required.</li>
      </ul>
      <p class="mt-4 text-sm text-slate-700">
        Travel distance is measured as a one-way distance from our service origin. Your event location is confirmed at booking. The exact travel fee will be disclosed as a separate labeled line item before your Booking Retainer is requested. Our service origin is not publicly disclosed.
      </p>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">Packages and add-ons</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        Pricing is provided in your personalized quote based on your event details, services selected, guest count, and event duration. Glitter tattoos, face gems, and balloon twisting may be available for your event, with pricing and availability included in your personalized quote.
      </p>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        For a detailed breakdown of <a href="/face-painting-cost-los-angeles/" class="text-orange-600 hover:underline">face painting cost in Los Angeles</a> for kids' birthday parties, including package examples, pricing factors, and travel fees, see our cost guide.
      </p>
    </section>

    <QuoteForm />
  </section>

  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: "pricing_view",
      source_page: window.location.pathname,
    });
    if (typeof window.gtag === "function") {
      window.gtag("event", "pricing_view", {
        source_page: window.location.pathname,
      });
    }
  </script>
</BaseLayout>
