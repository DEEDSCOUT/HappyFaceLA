---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import BookingCtaBlock from "../components/sections/BookingCtaBlock.astro";
import { serviceJsonLd, faqJsonLd } from "../utils/schema";

const canonicalPath = "/pricing/";
const pricingFaqs = [
  {
    question: "Do you publish exact pricing online?",
    answer:
      "Pricing is personalized based on your event date, location, guest count, service mix, and number of artists needed. Submit your party details so the team can review availability and follow up.",
  },
  {
    question: "What affects event pricing?",
    answer:
      "Date demand, travel, duration, add-ons, and staffing all affect final pricing.",
  },
  {
    question: "How do retainers work?",
    answer:
      "No payment is required when you first submit your party details. See the Booking Policy for Availability Hold and retainer details.",
  },
];
---

<BaseLayout
  title="Pricing for Face Painting & Party Entertainment in Los Angeles | Happy Faces LA"
  description="Pricing depends on event date, location, guest count, and services requested. Plan your party with Happy Faces LA."
  canonicalPath={canonicalPath}
  jsonLd={[
    serviceJsonLd(
      "Party Entertainment Pricing",
      `https://happyfacesla.com${canonicalPath}`,
    ),
    faqJsonLd(pricingFaqs),
  ]}
>
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Pricing", href: canonicalPath },
    ]}
  />
  <PageIntro
    title="Face Painting Pricing"
    description="Pricing depends on event date, location, number of guests, services requested, and artist count. Submit your party details so Happy Faces LA can review availability and follow up."
  />

  <section class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-10">
    <section class="rounded-2xl border border-orange-200 bg-orange-50 p-6">
      <h2 class="text-2xl font-bold text-slate-900">How pricing is reviewed</h2>
      <ol class="mt-4 space-y-2 text-sm text-slate-700">
        <li>1. Submit your event date, location, guest count, and services requested.</li>
        <li>2. Happy Faces LA reviews your party details, including any applicable travel fee.</li>
        <li>3. Happy Faces LA confirms artist availability before your booking is final.</li>
        <li>4. Availability Hold and retainer details are explained in the Booking Policy.</li>
      </ol>
      <p class="mt-4 text-sm text-slate-700">
        No payment is required when you submit your party details.
      </p>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">What affects price</h2>
      <ul class="mt-4 space-y-2 text-sm text-slate-700">
        <li>Event date and time demand</li>
        <li>City and travel distance</li>
        <li>Guest count and service speed requirements</li>
        <li>Add-ons, extra artists, and overtime</li>
      </ul>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">Travel Fees</h2>
      <ul class="mt-4 space-y-2 text-sm text-slate-700">
        <li><strong>0–20 miles:</strong> No travel fee.</li>
        <li><strong>More than 20 through 40 miles:</strong> $25 flat travel fee.</li>
        <li><strong>More than 40 through 60 miles:</strong> $50 flat travel fee; manual booking approval is required.</li>
        <li><strong>More than 60 miles:</strong> Custom plan and manual approval required.</li>
      </ul>
      <p class="mt-4 text-sm text-slate-700">
        Travel distance is measured as a one-way distance from our service origin. Any travel fee is
        disclosed as a separate labeled line item before an Availability Hold is offered. Our service
        origin is not publicly disclosed.
      </p>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">Packages and add-ons</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        Pricing is based on your event details, services selected, guest count, and event duration.
        Glitter tattoos, face gems, and balloon twisting may be available for your event, with pricing
        and availability reviewed after you submit your party details.
      </p>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        For a detailed breakdown of <a href="/face-painting-cost-los-angeles/" class="text-orange-600 hover:underline">face painting cost in Los Angeles</a> for kids' birthday parties, including package examples, pricing factors, and travel fees, see our cost guide.
      </p>
    </section>

    <BookingCtaBlock
      title="Ready to plan your party?"
      description="Use Plan My Party to share your event date, city, guest count, and services. Happy Faces LA will review your request and send next steps."
      primaryHref="/plan-my-party/"
      primaryLabel="Plan My Party"
    />
  </section>

  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: "pricing_view",
      source_page: window.location.pathname,
    });
    if (typeof window.gtag === "function") {
      window.gtag("event", "pricing_view", {
        source_page: window.location.pathname,
      });
    }
  </script>
</BaseLayout>
