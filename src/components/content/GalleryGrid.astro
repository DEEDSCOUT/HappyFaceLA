---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  title?: string;
  images: ImageItem[];
}

const { title = "Event gallery", images } = Astro.props;
---

<section>
  <h2 class="text-2xl font-bold text-slate-900">{title}</h2>
  <div class="mt-4 columns-1 gap-4 sm:columns-2 lg:columns-3">
    {images.map((image) => (
      <figure class="group mb-4 break-inside-avoid overflow-hidden rounded-2xl border border-slate-200 bg-white">
        <div class="overflow-hidden">
          <img
            loading="lazy"
            decoding="async"
            src={image.src}
            alt={image.alt}
            class="block h-auto w-full transition-transform duration-300 ease-out group-hover:scale-105"
          />
        </div>
      </figure>
    ))}
  </div>
</section>
