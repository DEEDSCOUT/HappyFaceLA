---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  title?: string;
  images: ImageItem[];
}

const { title = "Event gallery", images } = Astro.props;
---

<section>
  <h2 class="text-2xl font-bold text-slate-900">{title}</h2>
  <div class="mt-4 columns-2 lg:columns-3 gap-4">
    {images.map((image) => (
      <figure class="mb-4 break-inside-avoid overflow-hidden rounded-2xl border border-slate-200 bg-white">
        <img loading="lazy" decoding="async" src={image.src} alt={image.alt} class="w-full h-auto block" />
      </figure>
    ))}
  </div>
</section>
