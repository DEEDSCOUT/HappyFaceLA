---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
  <h3 class="text-xl font-semibold text-slate-900">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-slate-700">{description}</p>
  <a class="mt-4 inline-block text-sm font-semibold text-orange-600 hover:text-orange-700" href={href}>Explore service</a>
</article>
