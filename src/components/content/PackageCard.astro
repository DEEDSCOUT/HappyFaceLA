---
interface Props {
  name: string;
  bestFor: string;
  features: string[];
  duration: string;
  guestCapacity: string;
  startingPrice: string;
}

const { name, bestFor, features, duration, guestCapacity, startingPrice } = Astro.props;
---

<article class="rounded-2xl border border-orange-200 bg-white p-6 shadow-sm">
  <h3 class="text-xl font-semibold text-slate-900">{name}</h3>
  <p class="mt-2 text-sm text-slate-600">Best for: {bestFor}</p>
  <ul class="mt-4 space-y-2 text-sm text-slate-700">
    {features.map((feature) => <li>• {feature}</li>)}
  </ul>
  <dl class="mt-4 grid grid-cols-2 gap-3 text-xs text-slate-600">
    <div><dt class="font-semibold">Duration</dt><dd>{duration}</dd></div>
    <div><dt class="font-semibold">Guest Capacity</dt><dd>{guestCapacity}</dd></div>
    <div class="col-span-2"><dt class="font-semibold">Starting Price</dt><dd>{startingPrice}</dd></div>
  </dl>
  <a class="mt-5 inline-block rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white" href="/contact/" data-track-event="package_click">Get quote</a>
</article>
