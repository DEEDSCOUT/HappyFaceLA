---
import type { LocationItem } from "../../data/locations";
import FAQAccordion from "../content/FAQAccordion.astro";

interface Props {
  location: LocationItem;
}

const { location } = Astro.props;

const faqs = [
  {
    question: `What services are available in ${location.city}?`,
    answer: `Happy Faces LA offers face painting, balloon twisting, glitter tattoos, and face gems in ${location.city}.`,
  },
  {
    question: `Do you travel for events in ${location.city}?`,
    answer: `Yes. Serving Los Angeles and nearby areas. Share your event city or ZIP code for availability. Any travel fee is described as a separate labeled line item before you approve next steps.`,
  },
];
---

<section class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-10">
  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">
      Services available in {location.city}
    </h2>
    <p class="mt-3 text-sm leading-relaxed text-slate-700">
      {location.serviceIntro}
    </p>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <a
        href="/face-painting-los-angeles/"
        class="rounded-xl border border-slate-200 p-4 text-sm leading-relaxed text-slate-700 transition hover:border-orange-300"
      >
        <span class="block font-semibold text-slate-900">Face Painting</span>
        Cheek art, masks, butterflies, superheroes, and party-friendly designs
        paced for the age range and event length.
      </a>
      <a
        href="/balloon-twisting-los-angeles/"
        class="rounded-xl border border-slate-200 p-4 text-sm leading-relaxed text-slate-700 transition hover:border-orange-300"
      >
        <span class="block font-semibold text-slate-900">Balloon Twisting</span>
        Line-friendly balloon animals, flowers, swords, and wearable designs
        for high-energy party flow.
      </a>
      <a
        href="/glitter-tattoos-los-angeles/"
        class="rounded-xl border border-slate-200 p-4 text-sm leading-relaxed text-slate-700 transition hover:border-orange-300"
      >
        <span class="block font-semibold text-slate-900">Glitter Tattoos</span>
        Temporary sparkle designs that work well for festivals, school events,
        and guests who want a quick station.
      </a>
      <a
        href="/face-gems-face-jewelry-los-angeles/"
        class="rounded-xl border border-slate-200 p-4 text-sm leading-relaxed text-slate-700 transition hover:border-orange-300"
      >
        <span class="block font-semibold text-slate-900"
          >Face Gems & Face Jewelry</span
        >
        Photo-ready gem accents that pair well with glitter tattoos, cheek art,
        and themed celebrations.
      </a>
    </div>
    <p class="mt-4 text-sm text-slate-600">
      <a href="/services/" class="text-orange-600 hover:underline"
        >See all services</a
      >
      <span class="mx-2 text-slate-300">|</span>
      <a href="/plan-my-party/" class="text-orange-600 hover:underline"
        >Plan My Party</a
      >
      <span class="mx-2 text-slate-300">|</span>
      <a href="/pricing/" class="text-orange-600 hover:underline"
        >View pricing</a
      >
    </p>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">
      Best event types in {location.city}
    </h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      {
        location.eventSettings.map((setting) => (
          <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
            {setting}
          </div>
        ))
      }
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">
      Planning notes for {location.city}
    </h2>
    <ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate-700">
      {location.planningNotes.map((note) => <li>{note}</li>)}
    </ul>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Travel and setup notes</h2>
    <p class="mt-3 text-sm leading-relaxed text-slate-700">
      Serving {location.city} and nearby {location.county} areas on an
      availability-reviewed basis. Share your event city or ZIP code, event
      date, guest count, and service interests so the team can recommend a
      practical event plan.
    </p>
    <ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate-700">
      {location.setupNotes.map((note) => <li>{note}</li>)}
    </ul>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Nearby service areas</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {
        location.nearby.map((nearbySlug) => (
          <a
            class="rounded-full border border-slate-300 px-3 py-1 text-sm text-slate-700 hover:border-orange-500 hover:text-orange-600"
            href={`/service-areas/${nearbySlug}/`}
          >
            {nearbySlug
              .split("-")
              .map((part) => part[0].toUpperCase() + part.slice(1))
              .join(" ")}
          </a>
        ))
      }
    </div>
  </section>

  <FAQAccordion items={faqs} />

  <section class="rounded-2xl border border-orange-200 bg-orange-50 p-6">
    <div class="grid gap-4 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <h2 class="text-2xl font-bold text-orange-950">
          Ready to plan an event in {location.city}?
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-orange-900">
          Use Plan My Party for the canonical planning flow, or call/text the
          team if you prefer to talk through your event.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 md:justify-end">
        <a
          class="rounded-xl bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600"
          href="/plan-my-party/"
        >
          Plan My Party
        </a>
        <a
          class="rounded-xl border border-orange-300 px-5 py-3 text-sm font-semibold text-orange-950 hover:bg-orange-100"
          href="tel:3108002860"
          data-track-event="phone_click"
        >
          Call/Text (310) 800-2860
        </a>
      </div>
    </div>
  </section>
</section>
