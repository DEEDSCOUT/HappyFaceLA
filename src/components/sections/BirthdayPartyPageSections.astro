---
import QuoteForm from "../conversion/QuoteForm.astro";
import FAQAccordion from "../content/FAQAccordion.astro";

const faqs = [
  {
    question: "What birthday party services can I request?",
    answer:
      "Happy Faces LA offers face painting, balloon twisting, glitter tattoos and face gems for children's birthday celebrations."
  },
  {
    question: "How much does face painting for a birthday party start at?",
    answer:
      "Face Painting Parties from $150. Share your event city or ZIP code for availability."
  },
  {
    question: "Where does Happy Faces LA provide birthday party entertainment?",
    answer:
      "Serving Los Angeles and nearby areas. Share your event city or ZIP code for availability."
  }
];
---

<section class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-10">
  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Birthday party entertainment families can request</h2>
    <p class="mt-3 text-sm text-slate-700">
      Choose the creative services that fit your celebration: face painting, balloon twisting, glitter tattoos or face gems. Share your preferred services when requesting availability.
    </p>
    <ul class="mt-4 space-y-2 text-sm text-slate-700">
      <li><a href="/face-painting-los-angeles/" class="text-orange-600 hover:underline">Face Painting</a> — custom designs for all ages, 3–7 minutes per child</li>
      <li><a href="/balloon-twisting-los-angeles/" class="text-orange-600 hover:underline">Balloon Twisting</a> — swords, animals, crowns, flowers, and more</li>
      <li><a href="/glitter-tattoos-los-angeles/" class="text-orange-600 hover:underline">Glitter Tattoos</a> — temporary designs for parties and festival stations</li>
      <li><a href="/face-gems-face-jewelry-los-angeles/" class="text-orange-600 hover:underline">Face Gems &amp; Face Jewelry</a> — festival and princess looks, photo-ready</li>
    </ul>
    <p class="mt-4 text-sm text-slate-600">
      <a href="/gallery/" class="text-orange-600 hover:underline">Browse the gallery →</a>
      <span class="mx-2 text-slate-300">|</span>
      <a href="/pricing/" class="text-orange-600 hover:underline">View pricing →</a>
    </p>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Plan your child's birthday celebration</h2>
    <p class="mt-3 text-sm text-slate-700">
      Tell us your event date, city or ZIP code and preferred services. Browse our gallery for design inspiration, then request availability and next steps.
    </p>
  </section>

  <FAQAccordion items={faqs} />
  <QuoteForm />
</section>
