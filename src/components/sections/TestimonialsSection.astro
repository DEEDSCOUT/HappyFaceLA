---
import TestimonialCard from "../content/TestimonialCard.astro";
import { testimonials } from "../../data/testimonials";

interface Props {
  /** Filter to only show testimonials matching this event type */
  eventType?: string;
  /** Maximum number of testimonials to show. Defaults to all. */
  limit?: number;
}

const { eventType, limit } = Astro.props;

let visible = testimonials.filter((t) => t.permissionConfirmed);
if (eventType) {
  visible = visible.filter((t) => t.eventType.toLowerCase().includes(eventType.toLowerCase()));
}
if (limit) {
  visible = visible.slice(0, limit);
}

const hasTestimonials = visible.length > 0;
---

{hasTestimonials ? (
  <section class="mx-auto w-full max-w-6xl px-4 py-10">
    <h2 class="text-2xl font-bold text-slate-900">What customers say</h2>

    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {visible.map((t) => <TestimonialCard testimonial={t} />)}
    </div>
  </section>
) : null}
