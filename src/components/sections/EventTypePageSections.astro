---
import GalleryGrid from "../content/GalleryGrid.astro";
import QuoteForm from "../conversion/QuoteForm.astro";
import FAQAccordion from "../content/FAQAccordion.astro";

interface Props {
  eventType: string;
}

const { eventType } = Astro.props;

const images = [
  {
    src: "/images/placeholders/happy-faces-la-hero-placeholder.svg",
    alt: `${eventType} placeholder image for owner replacement`
  },
  {
    src: "/images/placeholders/happy-faces-la-hero-placeholder.svg",
    alt: `${eventType} event setup placeholder image`
  }
];

const faqs = [
  {
    question: `What services can we combine for ${eventType}?`,
    answer:
      "You can combine face painting, balloon twisting, glitter tattoos, and face gems based on attendance and timeline."
  },
  {
    question: "How early should we book?",
    answer:
      "Popular weekend times can fill quickly, so early booking is recommended whenever possible."
  }
];
---

<section class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-10">
  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Built for {eventType}</h2>
    <p class="mt-3 text-sm text-slate-700">
      Happy Faces LA provides event-ready entertainment with clear communication, flexible packages, and fast quote turnaround for {eventType.toLowerCase()}.
    </p>
  </section>

  <GalleryGrid title="Event inspiration" images={images} />
  <FAQAccordion items={faqs} />
  <QuoteForm />
</section>
