---
import FAQAccordion from "../content/FAQAccordion.astro";
import BookingCtaBlock from "./BookingCtaBlock.astro";

interface Props {
  eventType: string;
}

const { eventType } = Astro.props;

const faqs = [
  {
    question: `What services can we combine for ${eventType}?`,
    answer:
      "You can combine face painting, balloon twisting, glitter tattoos, and face gems based on attendance and timeline. School, corporate, institutional, and community events are available by custom quote only.",
  },
  {
    question: "How early should we book?",
    answer:
      "Popular weekend times can fill quickly, so early booking is recommended whenever possible.",
  },
];
---

<section class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-10">
  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Built for {eventType}</h2>
    <p class="mt-3 text-sm text-slate-700">
      School events, corporate gatherings, and institutional or community events
      are available by custom quote only. Pricing, availability, and services
      depend on event scale, location, and specific requirements. Use Plan My
      Party to share your event details and receive next steps.
    </p>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-lg font-bold text-slate-900">
      Services available for {eventType}
    </h2>
    <ul class="mt-3 space-y-2 text-sm text-slate-700">
      <li>
        <a
          href="/face-painting-los-angeles/"
          class="text-orange-600 hover:underline">Face Painting</a
        > — custom designs for all ages, 3–7 minutes per child
      </li>
      <li>
        <a
          href="/balloon-twisting-los-angeles/"
          class="text-orange-600 hover:underline">Balloon Twisting</a
        > — swords, animals, crowns, flowers, and more
      </li>
      <li>
        <a
          href="/glitter-tattoos-los-angeles/"
          class="text-orange-600 hover:underline">Glitter Tattoos</a
        > — temporary designs for parties and festival stations
      </li>
      <li>
        <a
          href="/face-gems-face-jewelry-los-angeles/"
          class="text-orange-600 hover:underline">Face Gems & Face Jewelry</a
        > — festival and princess looks, photo-ready
      </li>
    </ul>
    <p class="mt-4 text-sm text-slate-600">
      <a href="/services/" class="text-orange-600 hover:underline"
        >See all services →</a
      >
      <span class="mx-2 text-slate-300">|</span>
      <a href="/pricing/" class="text-orange-600 hover:underline"
        >View pricing →</a
      >
    </p>
  </section>

  <FAQAccordion items={faqs} />
  <BookingCtaBlock
    title={`Ready to plan ${eventType}?`}
    description="Use Plan My Party to send your event date, location, guest count, and service interests through the current intake flow."
    primaryHref="/plan-my-party/"
    primaryLabel="Plan My Party"
  />
</section>
