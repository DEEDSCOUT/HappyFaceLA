---
import type { ServiceItem } from "../../data/services";
import GalleryGrid from "../content/GalleryGrid.astro";
import FAQAccordion from "../content/FAQAccordion.astro";
import PackageCard from "../content/PackageCard.astro";
import QuoteForm from "../conversion/QuoteForm.astro";
import ServiceAreaLinks from "./ServiceAreaLinks.astro";
import ServiceCrossSell from "./ServiceCrossSell.astro";
import BookingCtaBlock from "./BookingCtaBlock.astro";
import type { FaqItem } from "../../data/faqs";
import { packages } from "../../data/packages";
import { galleryItems } from "../../data/gallery";

interface Props {
  service: ServiceItem;
  faqs: FaqItem[];
}

const { service, faqs } = Astro.props;

// Use real gallery images for this service, falling back to placeholder if none
const serviceGallery = galleryItems
  .filter((item) => item.permissionConfirmed && item.service === service.name && !item.src.endsWith(".svg"))
  .map((item) => ({ src: item.src, alt: item.alt }));

const gallery = serviceGallery.length > 0
  ? serviceGallery
  : [
      { src: "/images/placeholders/happy-faces-la-hero-placeholder.svg", alt: `${service.name} photo — coming soon` },
      { src: "/images/placeholders/happy-faces-la-hero-placeholder.svg", alt: `${service.name} photo — coming soon` },
      { src: "/images/placeholders/happy-faces-la-hero-placeholder.svg", alt: `${service.name} photo — coming soon` },
    ];
---

<section class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-10">
  {service.image && (
    <div class="overflow-hidden rounded-2xl">
      <img
        src={service.image}
        alt={service.imageAlt ?? service.name}
        width="1400"
        height="788"
        class="w-full bg-slate-100 object-contain"
        style="aspect-ratio:16/9;"
        loading="eager"
        decoding="async"
      />
    </div>
  )}

  <ServiceCrossSell
    currentSlug={service.slug}
    title={service.crossSellTitle}
    description={service.crossSellDescription}
  />

  <article class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Who this service is best for</h2>
    <p class="mt-3 text-sm leading-relaxed text-slate-700">
      {service.intro} This page is designed for birthdays, school events, festivals, corporate family days, and private celebrations in Los Angeles.
    </p>
  </article>

  <!-- Service proof section -->
  <div class="grid gap-6 md:grid-cols-3">
    <article class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-lg font-bold text-slate-900">What it includes</h2>
      <ul class="mt-3 space-y-2 text-sm text-slate-700">
        {service.whatItIncludes.map((item) => (
          <li class="flex gap-2">
            <span class="mt-0.5 shrink-0 text-orange-500" aria-hidden="true">✓</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-lg font-bold text-slate-900">Best for</h2>
      <ul class="mt-3 space-y-2 text-sm text-slate-700">
        {service.bestFor.map((item) => (
          <li class="flex gap-2">
            <span class="mt-0.5 shrink-0 text-slate-400" aria-hidden="true">→</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-6">
      <h2 class="text-lg font-bold text-slate-900">Add-ons available</h2>
      <ul class="mt-3 space-y-2 text-sm text-slate-700">
        {service.addOns.map((item) => (
          <li class="flex gap-2">
            <span class="mt-0.5 shrink-0 text-orange-400" aria-hidden="true">+</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </article>
  </div>

  <GalleryGrid title={`${service.name} Gallery`} images={gallery} />

  <section>
    <h2 class="text-2xl font-bold text-slate-900">Package options</h2>
    <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {packages.slice(0, 3).map((item) => <PackageCard {...item} />)}
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Safety and trust notes</h2>
    <ul class="mt-4 space-y-2 text-sm text-slate-700">
      <li>Happy Faces LA uses professional cosmetic-grade face paints, cosmetic glitter, skin-safe temporary tattoos, and face/body-safe adhesives for gems and face jewelry. We do not use craft glitter or craft glue on the skin.</li>
      <li>For hygiene, supplies are kept clean during setup and throughout the event. Products are not applied to broken, irritated, sunburned, or visibly contagious skin. Single-use applicators are used where appropriate.</li>
      <li>Guests with sensitive skin, allergies, skin conditions, or recent reactions should let us know before service so designs can be adjusted or skipped when needed.</li>
      <li>Insured through Body Art Insurance. COI availability is confirmed during booking.</li>
      <li>We serve Los Angeles County, Orange County, and Ventura County. Setup details are confirmed at booking.</li>
    </ul>
  </section>

  <ServiceAreaLinks />
  <FAQAccordion items={faqs} />
  <BookingCtaBlock />
  <QuoteForm />
</section>
