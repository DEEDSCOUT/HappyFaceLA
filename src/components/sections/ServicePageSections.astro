---
import type { ServiceItem } from "../../data/services";
import GalleryGrid from "../content/GalleryGrid.astro";
import FAQAccordion from "../content/FAQAccordion.astro";
import PackageCard from "../content/PackageCard.astro";
import QuoteForm from "../conversion/QuoteForm.astro";
import ServiceAreaLinks from "./ServiceAreaLinks.astro";
import type { FaqItem } from "../../data/faqs";
import { packages } from "../../data/packages";

interface Props {
  service: ServiceItem;
  faqs: FaqItem[];
}

const { service, faqs } = Astro.props;

const gallery = [
  {
    src: "/images/placeholders/happy-faces-la-hero-placeholder.svg",
    alt: `${service.name} placeholder image for owner replacement`
  },
  {
    src: "/images/placeholders/happy-faces-la-hero-placeholder.svg",
    alt: `${service.name} setup placeholder image for owner replacement`
  },
  {
    src: "/images/placeholders/happy-faces-la-hero-placeholder.svg",
    alt: `${service.name} event placeholder image for owner replacement`
  }
];
---

<section class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-10">
  <article class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Who this service is best for</h2>
    <p class="mt-3 text-sm leading-relaxed text-slate-700">
      {service.intro} This page is designed for birthdays, school events, festivals, corporate family days, and private celebrations in Los Angeles.
    </p>
  </article>

  <GalleryGrid title={`${service.name} Gallery`} images={gallery} />

  <section>
    <h2 class="text-2xl font-bold text-slate-900">Package options</h2>
    <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {packages.slice(0, 3).map((item) => <PackageCard {...item} />)}
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-2xl font-bold text-slate-900">Safety and trust notes</h2>
    <ul class="mt-4 space-y-2 text-sm text-slate-700">
      <li>Products and hygiene process: TBD_BY_OWNER.</li>
      <li>Insurance and COI availability: TBD_BY_OWNER.</li>
      <li>Travel radius and setup requirements: TBD_BY_OWNER.</li>
    </ul>
  </section>

  <ServiceAreaLinks />
  <FAQAccordion items={faqs} />
  <QuoteForm />
</section>
