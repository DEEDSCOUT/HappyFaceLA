---
import { priorityLocations } from "../../data/locations";
---

<section>
  <h2 class="text-2xl font-bold text-slate-900">Service Areas</h2>
  <p class="mt-2 text-sm text-slate-600">Happy Faces LA serves Los Angeles and nearby LA-area neighborhoods.</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {priorityLocations.map((location) => (
      <a class="rounded-full border border-slate-300 px-3 py-1 text-sm text-slate-700 hover:border-orange-500 hover:text-orange-600" href={`/service-areas/${location.slug}/`}>
        {location.city}
      </a>
    ))}
  </div>
</section>
