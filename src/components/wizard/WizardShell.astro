---
import WizardProgress from './WizardProgress.astro';
import StepEventType from './steps/StepEventType.astro';
import StepServices from './steps/StepServices.astro';
import StepKidsCount from './steps/StepKidsCount.astro';
import StepDesignStyle from './steps/StepDesignStyle.astro';
import StepDuration from './steps/StepDuration.astro';
import StepDateLocation from './steps/StepDateLocation.astro';
import StepRecommendation from './steps/StepRecommendation.astro';
import StepQuoteRequest from './steps/StepQuoteRequest.astro';
import { lookbookItems } from '../../data/lookbook';
import '../../styles/wizard.css';

const lookbookInspirationCatalog = lookbookItems.map((item) => ({
  publicLookSlug: item.slug,
  publicTitle: item.title,
  service: item.service,
  serviceLabel: item.serviceLabel,
  designStyle: item.designStyle,
  designStyleLabel: item.speedLabel,
  category: item.category,
  thumbnailSrc: item.image.preview,
}));
---

<div id="hfla-wizard" class="max-w-xl mx-auto px-4 py-8">

  <div id="lookbook-prefill-banner" class="wizard-notice mb-5 hidden" aria-live="polite"></div>
  <script id="lookbook-inspiration-catalog" type="application/json" set:html={JSON.stringify(lookbookInspirationCatalog)}></script>

  <!-- Progress bar (hidden until wizard initializes) -->
  <div id="wizard-progress-wrapper" class="hidden">
    <WizardProgress totalSteps={8} />
  </div>

  <!-- All wizard steps (each starts hidden; JS shows the active one) -->
  <div id="wizard-steps-container">
    <StepEventType />
    <StepServices />
    <StepKidsCount />
    <StepDesignStyle />
    <StepDuration />
    <StepDateLocation />
    <StepRecommendation />
    <StepQuoteRequest />
  </div>

  <!-- Navigation buttons (hidden on step 7 which has its own CTA, and step 8 which has submit) -->
  <div id="wizard-nav" class="mt-6 flex items-center justify-between gap-4 hidden">
    <button
      id="btn-back"
      type="button"
      class="text-sm font-medium text-slate-600 hover:text-slate-900 focus:outline-none focus:underline disabled:opacity-40 disabled:cursor-not-allowed"
      aria-label="Go back to previous step"
    >
      ← Back
    </button>
    <button
      id="btn-next"
      type="button"
      class="rounded-xl bg-orange-500 px-6 py-3 text-sm font-semibold text-white hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:ring-offset-2 disabled:opacity-60 disabled:cursor-not-allowed transition-colors"
      aria-label="Go to next step"
    >
      Next →
    </button>
  </div>

  <!-- Validation error summary -->
  <div id="wizard-validation-error" class="mt-3 text-rose-700 text-sm hidden" role="alert" aria-live="polite"></div>

  <!-- Confirmation screen (shown after successful submission) -->
  <div id="wizard-confirmation" class="wizard-confirmation hidden" aria-live="polite">
    <div class="wizard-confirmation-icon" aria-hidden="true">🎉</div>
    <h2 class="text-2xl font-bold text-slate-900">Quote request received!</h2>
    <p id="wizard-confirm-name" class="mt-3 text-slate-700 leading-relaxed"></p>
    <p id="wizard-confirm-reference" class="mt-3 rounded-lg bg-orange-50 px-3 py-2 text-sm font-semibold text-orange-900 hidden"></p>
    <ul class="mt-5 flex flex-col gap-2 text-sm text-slate-700">
      <li class="flex items-start gap-2">
        <span class="text-orange-500 font-bold mt-0.5" aria-hidden="true">•</span>
        <span><strong>Your date is NOT reserved yet.</strong></span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-orange-500 font-bold mt-0.5" aria-hidden="true">•</span>
        <span>No payment is due until you approve your quote.</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-orange-500 font-bold mt-0.5" aria-hidden="true">•</span>
        <span>When an instant quote is available, a <strong>20% Availability Hold</strong> authorizes the retainer. Booking is confirmed only after Happy Faces LA sends confirmation.</span>
      </li>
    </ul>
    <p id="wizard-confirm-email" class="mt-4 text-sm text-slate-600"></p>
    <div class="mt-6 flex flex-wrap gap-3">
      <button
        id="btn-plan-another"
        type="button"
        class="rounded-xl bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-400"
      >
        Plan Another Party
      </button>
      <a
        href="/"
        class="rounded-xl border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-400"
      >
        Back to Home
      </a>
    </div>
  </div>
</div>

<script>
  // Happy Faces LA guided selling wizard controller.

  import {
    computeRecommendation,
    getRecommendedDuration,
    getConflictWarning,
    formatDurationLabel,
    bucketFromCount,
    CAPACITY_GUIDANCE,
    SPEED_GUIDANCE,
    KIDS_LABELS,
  } from '../../lib/wizard/recommendation-engine.ts';
  import { validateStep, isDateInPast } from '../../lib/wizard/validation.ts';
  import { calculateCapacity, resolveKidsCount } from '../../lib/booking/capacity-engine.ts';
  import { assessEligibility } from '../../lib/booking/eligibility.ts';
  import {
    classifyQuoteOutcome,
    CLASSIFICATION_LABELS,
    CUSTOM_PLAN_COPY,
  } from '../../lib/wizard/quote-classification.ts';

  // ── Types (inline for bundler compatibility) ──────────────────
  type EventType = 'birthday-party'|'school-event'|'corporate-family-day'|'festival-community'|'other';
  type Service   = 'face-painting'|'balloon-twisting'|'glitter-tattoos'|'face-gems'|'combo'|'not-sure';
  type Kids      = '1-10'|'11-18'|'19-25'|'26-40'|'40-plus'|'not-sure';
  type Style     = 'quick-cheek-arm'|'standard-party'|'full-face'|'fast-event-menu'|'not-sure';
  type Duration  = 60|90|120|180|240|'custom'|null;
  type PreferredContactMethod = 'any'|'text'|'phone'|'email';

  interface LookbookInspiration {
    publicLookSlug: string;
    publicTitle: string;
    service: 'face-painting'|'balloon-twisting'|'face-gems';
    serviceLabel: string;
    designStyle: string;
    designStyleLabel: string;
    category?: string;
    thumbnailSrc: string;
  }

  interface Answers {
    eventType: EventType|null;
    services: Service[];
    kidsCountBucket: Kids|null;
    kidsCountActual: number|null;
    designStyle: Style|null;
    selectedDurationOption: Duration;
    eventDate: string|null;
    eventTime: string|null;
    eventCity: string;
    venueName: string;
    specialRequests: string;
    travelMiles: number|null;
    firstName: string;
    lastName: string;
    email: string;
    phone: string;
    preferredContactMethod: PreferredContactMethod;
    lookbookService: string;
    lookbookDesignStyle: string;
    publicLookSlug: string;
    publicLookTitle: string;
    lookbookCategory: string;
    inspirationImageId: string;
    lookbookInspirations: LookbookInspiration[];
  }

  // ── State ─────────────────────────────────────────────────────
  let currentStep = 1;
  const TOTAL_STEPS = 8;
  const answers: Answers = {
    eventType: null,
    services: [],
    kidsCountBucket: null,
    kidsCountActual: null,
    designStyle: null,
    selectedDurationOption: null,
    eventDate: null,
    eventTime: null,
    eventCity: '',
    venueName: '',
    specialRequests: '',
    travelMiles: null,
    firstName: '',
    lastName: '',
    email: '',
    phone: '',
    preferredContactMethod: 'any',
    lookbookService: '',
    lookbookDesignStyle: '',
    publicLookSlug: '',
    publicLookTitle: '',
    lookbookCategory: '',
    inspirationImageId: '',
    lookbookInspirations: [],
  };
  let recommendedDuration: Duration = null;
  let initialized = false;
  const WIZARD_PROGRESS_KEY = 'hflaWizardProgressV1';
  const WIZARD_QUOTE_IDEMPOTENCY_KEY = 'hflaWizardQuoteRequestIdempotencyV1';

  // ── Display labels ────────────────────────────────────────────
  const EVENT_LABELS: Record<string, string> = {
    'birthday-party':       'Birthday party',
    'school-event':         'School event',
    'corporate-family-day': 'Corporate event or family day',
    'festival-community':   'Festival or community event',
    'other':                'Other',
  };
  const SERVICE_LABELS: Record<string, string> = {
    'face-painting':   'Face painting',
    'balloon-twisting':'Balloon twisting',
    'glitter-tattoos': 'Glitter tattoos',
    'face-gems':       'Face gems',
    'combo':           'Combo package',
    'not-sure':        'Not sure yet',
  };
  const DURATION_VALUES: Record<string, Duration> = {
    '60': 60, '90': 90, '120': 120, '180': 180, '240': 240, 'custom': 'custom',
  };
  const STYLE_LABELS: Record<string, string> = {
    'quick-cheek-arm': 'Quick cheek or arm designs',
    'standard-party':  'Standard party designs',
    'full-face':       'Wow or full-face designs',
    'fast-event-menu': 'Fast event menu',
    'not-sure':        'Recommended designs',
  };
  // Per-range placeholder hint for the exact/estimated child-count field.
  const EXACT_PLACEHOLDER: Record<string, string> = {
    '1-10': 'e.g. 8', '11-18': 'e.g. 14', '19-25': 'e.g. 22',
    '26-40': 'e.g. 28', '40-plus': 'e.g. 80', 'not-sure': 'e.g. 28',
  };
  // Customer-safe label for each travel band value emitted by the Step 6 select.
  const TRAVEL_BAND_LABELS: Record<number, string> = {
    0:  'Within 20 miles — no travel fee',
    30: 'More than 20–40 miles — $25 travel fee',
    50: 'More than 40–60 miles — manual approval required',
    70: 'More than 60 miles — custom quote',
  };

  // ── Helpers ───────────────────────────────────────────────────
  function qs<T extends Element>(sel: string): T|null {
    return document.querySelector<T>(sel);
  }
  function hide(el: Element|null) { el?.classList.add('hidden'); }
  function show(el: Element|null) { el?.classList.remove('hidden'); }

  function persistWizardProgress() {
    try {
      sessionStorage.setItem(WIZARD_PROGRESS_KEY, JSON.stringify({
        currentStep,
        answers: {
          ...answers,
          lookbookInspirations: answers.lookbookInspirations.slice(0, 6),
        },
      }));
    } catch {
      // Ignore storage access issues.
    }
  }

  function clearWizardProgress() {
    try {
      sessionStorage.removeItem(WIZARD_PROGRESS_KEY);
      sessionStorage.removeItem(WIZARD_QUOTE_IDEMPOTENCY_KEY);
    } catch {
      // Ignore storage access issues.
    }
  }

  function getQuoteRequestIdempotencyKey(): string {
    try {
      const existing = sessionStorage.getItem(WIZARD_QUOTE_IDEMPOTENCY_KEY);
      if (existing && /^qrq_[a-z0-9-]{16,90}$/i.test(existing)) return existing;
      const random = typeof crypto !== 'undefined' && 'randomUUID' in crypto
        ? crypto.randomUUID()
        : `${Date.now()}-${Math.random().toString(36).slice(2)}`;
      const key = `qrq_${String(random).toLowerCase().replace(/[^a-z0-9-]/g, '').slice(0, 80)}`;
      sessionStorage.setItem(WIZARD_QUOTE_IDEMPOTENCY_KEY, key);
      return key;
    } catch {
      const random = typeof crypto !== 'undefined' && 'randomUUID' in crypto
        ? crypto.randomUUID()
        : `${Date.now()}-${Math.random().toString(36).slice(2)}`;
      return `qrq_${String(random).toLowerCase().replace(/[^a-z0-9-]/g, '').slice(0, 80)}`;
    }
  }

  function restoreWizardProgress(): boolean {
    try {
      const raw = sessionStorage.getItem(WIZARD_PROGRESS_KEY);
      if (!raw) return false;
      const parsed = JSON.parse(raw) as { currentStep?: unknown; answers?: Partial<Answers> };
      if (!parsed.answers) return false;
      Object.assign(answers, parsed.answers);
      const savedStep = Number(parsed.currentStep);
      if (Number.isInteger(savedStep) && savedStep >= 1 && savedStep <= TOTAL_STEPS) {
        currentStep = savedStep;
      }
      return true;
    } catch {
      return false;
    }
  }

  function hydrateWizardControls() {
    if (answers.eventType) {
      const input = qs<HTMLInputElement>(`#step1-options input[value="${answers.eventType}"]`);
      if (input) input.checked = true;
      markOptionSelected('step1-options', answers.eventType);
      const fb = qs('#step1-feedback');
      if (fb) {
        fb.textContent = STEP1_FEEDBACK[answers.eventType] ?? '';
        show(fb);
      }
    }

    document.querySelectorAll<HTMLInputElement>('#step2-options input[type="checkbox"]').forEach((input) => {
      input.checked = answers.services.includes(input.value as Service);
    });
    if (answers.services.length) markOptionSelected('step2-options', answers.services[0], true);

    if (answers.kidsCountBucket) {
      const input = qs<HTMLInputElement>(`#step3-options input[value="${answers.kidsCountBucket}"]`);
      if (input) input.checked = true;
      markOptionSelected('step3-options', answers.kidsCountBucket);
      const exactWrapper = qs('#step3-exact-count');
      const exactInput = qs<HTMLInputElement>('#field-kidsExact');
      if (exactInput) {
        exactInput.value = typeof answers.kidsCountActual === 'number' ? String(answers.kidsCountActual) : '';
        exactInput.placeholder = EXACT_PLACEHOLDER[answers.kidsCountBucket] ?? 'e.g. 12';
        exactInput.required = answers.kidsCountBucket !== 'not-sure';
      }
      const reqMark = qs('#step3-exact-required');
      if (answers.kidsCountBucket === 'not-sure') {
        hide(exactWrapper);
        hide(reqMark);
        hide(qs('#step3-estimate-hint'));
      } else {
        show(exactWrapper);
        show(reqMark);
        show(qs('#step3-estimate-hint'));
      }
      updateKidsGuidance();
    }

    if (answers.designStyle) {
      const input = qs<HTMLInputElement>(`#step4-options input[value="${answers.designStyle}"]`);
      if (input) input.checked = true;
      markOptionSelected('step4-options', answers.designStyle);
      const guidance = qs('#step4-guidance');
      if (guidance) {
        guidance.textContent = SPEED_GUIDANCE[answers.designStyle] ?? '';
        show(guidance);
      }
    }

    if (answers.selectedDurationOption !== null) {
      const value = String(answers.selectedDurationOption);
      const input = qs<HTMLInputElement>(`#step5-options input[value="${value}"]`);
      if (input) {
        input.checked = true;
        markOptionSelected('step5-options', value);
      }
    }

    const fieldValues: Array<[string, string | number | null]> = [
      ['eventDate', answers.eventDate],
      ['eventTime', answers.eventTime],
      ['eventCity', answers.eventCity],
      ['venueName', answers.venueName],
      ['specialRequests', answers.specialRequests],
      ['travelBand', answers.travelMiles],
      ['firstName', answers.firstName],
      ['lastName', answers.lastName],
      ['email', answers.email],
      ['phone', answers.phone],
    ];
    fieldValues.forEach(([id, value]) => {
      const field = qs<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(`#field-${id}`);
      if (field && value !== null && value !== undefined) field.value = String(value);
    });
  }

  // Item 8: clear the step-level validation error as soon as the customer acts,
  // so a resolved error never lingers after the field/selection is fixed.
  function clearValidationError() { hide(qs('#wizard-validation-error')); }

  function track(eventName: string, params: Record<string, unknown> = {}) {
    const trackedWindow = window as Window & {
      dataLayer?: unknown[];
      gtag?: (command: string, eventName: string, params: Record<string, unknown>) => void;
    };
    trackedWindow.dataLayer = trackedWindow.dataLayer || [];
    trackedWindow.dataLayer.push({ event: eventName, ...params });
    if (typeof trackedWindow.gtag === 'function') {
      trackedWindow.gtag('event', eventName, params);
    }
  }

  function readSafeParam(params: URLSearchParams, key: string, maxLength = 80): string {
    const value = (params.get(key) || '').trim();
    return value.replace(/[^\w\s.,/&()+-]/g, '').slice(0, maxLength);
  }

  function sanitizeText(value: unknown, maxLength = 120): string {
    return String(value ?? '').replace(/[^\w\s.,/&()+-]/g, '').trim().slice(0, maxLength);
  }

  function sanitizeLookbookInspiration(raw: unknown): LookbookInspiration | null {
    const source = raw as Partial<LookbookInspiration> | null;
    if (!source) return null;
    const item: LookbookInspiration = {
      publicLookSlug: sanitizeText(source.publicLookSlug, 80),
      publicTitle: sanitizeText(source.publicTitle, 120),
      service: sanitizeText(source.service, 40) as LookbookInspiration['service'],
      serviceLabel: sanitizeText(source.serviceLabel, 40),
      designStyle: sanitizeText(source.designStyle, 40),
      designStyleLabel: sanitizeText(source.designStyleLabel, 60),
      category: sanitizeText(source.category, 80),
      thumbnailSrc: sanitizeText(source.thumbnailSrc, 160),
    };
    if (!/^[a-z0-9-]+$/.test(item.publicLookSlug)) return null;
    if (!['face-painting', 'balloon-twisting', 'face-gems'].includes(item.service)) return null;
    if (!item.thumbnailSrc.startsWith('/images/party-lookbook/') || item.thumbnailSrc.includes('..')) return null;
    return item;
  }

  function getLookbookCatalog(): LookbookInspiration[] {
    const el = qs<HTMLScriptElement>('#lookbook-inspiration-catalog');
    if (!el?.textContent) return [];
    try {
      const parsed = JSON.parse(el.textContent) as unknown[];
      return Array.isArray(parsed) ? parsed.map(sanitizeLookbookInspiration).filter(Boolean) as LookbookInspiration[] : [];
    } catch {
      return [];
    }
  }

  function readSessionBoard(): LookbookInspiration[] {
    try {
      const parsed = JSON.parse(sessionStorage.getItem('hflaLookbookBoard') || '[]') as unknown[];
      return Array.isArray(parsed) ? parsed.map(sanitizeLookbookInspiration).filter(Boolean).slice(0, 6) as LookbookInspiration[] : [];
    } catch {
      return [];
    }
  }

  function readSlugFallback(params: URLSearchParams): string[] {
    return sanitizeText(params.get('inspirations') || '', 500)
      .split(',')
      .map((slug) => slug.trim())
      .filter((slug) => /^[a-z0-9-]+$/.test(slug))
      .slice(0, 6);
  }

  function renderLookbookBoardBanner(items: LookbookInspiration[]) {
    const banner = qs<HTMLElement>('#lookbook-prefill-banner');
    if (!banner || !items.length) return;
    banner.innerHTML = '';

    const title = document.createElement('h2');
    title.className = 'text-lg font-bold text-slate-950';
    title.textContent = 'Your inspiration board';
    banner.appendChild(title);

    const body = document.createElement('p');
    body.className = 'mt-2 text-sm leading-6 text-slate-700';
    body.textContent =
      "We'll use these looks as style inspiration when recommending your party plan. Final designs may vary by guest count, time window, and artist recommendation.";
    banner.appendChild(body);

    const list = document.createElement('div');
    list.className = 'mt-4 grid gap-3';
    items.forEach((item) => {
      const row = document.createElement('div');
      row.className = 'grid grid-cols-[56px_1fr] gap-3 rounded-lg border border-slate-200 bg-white p-2';

      const img = document.createElement('img');
      img.src = item.thumbnailSrc;
      img.alt = item.publicTitle;
      img.className = 'h-14 w-14 rounded-md object-cover';
      row.appendChild(img);

      const text = document.createElement('div');
      const itemTitle = document.createElement('p');
      itemTitle.className = 'text-sm font-bold text-slate-950';
      itemTitle.textContent = item.publicTitle;
      text.appendChild(itemTitle);

      const meta = document.createElement('p');
      meta.className = 'mt-1 text-xs font-semibold text-slate-600';
      const labels = [item.serviceLabel || SERVICE_LABELS[item.service] || item.service];
      if (item.designStyleLabel && item.designStyleLabel.toLowerCase() !== labels[0].toLowerCase()) {
        labels.push(item.designStyleLabel);
      }
      meta.textContent = labels.join(' / ');
      text.appendChild(meta);
      row.appendChild(text);
      list.appendChild(row);
    });
    banner.appendChild(list);

    const link = document.createElement('a');
    link.href = '/gallery';
    link.className = 'mt-4 inline-flex text-sm font-bold text-orange-700 underline-offset-4 hover:underline focus:outline-none focus:ring-2 focus:ring-orange-400';
    link.textContent = 'Change looks';
    banner.appendChild(link);
    show(banner);
  }

  function applyServicesFromLookbook(items: LookbookInspiration[]) {
    const uniqueServices = Array.from(new Set(items.map((item) => item.service))).filter(Boolean) as Service[];
    if (!uniqueServices.length) return;
    answers.services = uniqueServices;
    answers.lookbookService = uniqueServices.length === 1 ? uniqueServices[0] : 'combo';
    document.querySelectorAll<HTMLInputElement>('#step2-options input[type="checkbox"]').forEach((input) => {
      input.checked = uniqueServices.includes(input.value as Service);
    });
    markOptionSelected('step2-options', uniqueServices[0], true);
  }

  function applyDesignStyleFromLookbook(items: LookbookInspiration[]) {
    const allowedStyles: Style[] = ['quick-cheek-arm', 'standard-party', 'full-face', 'fast-event-menu', 'not-sure'];
    const uniqueStyles = Array.from(new Set(items.map((item) => item.designStyle))).filter((style): style is Style =>
      allowedStyles.includes(style as Style),
    );
    if (uniqueStyles.length !== 1) return;
    const designStyle = uniqueStyles[0];
    answers.designStyle = designStyle;
    answers.lookbookDesignStyle = designStyle;
    const input = qs<HTMLInputElement>(`#step4-options input[value="${designStyle}"]`);
    if (input) input.checked = true;
    markOptionSelected('step4-options', designStyle);
    const guidance = qs('#step4-guidance');
    if (guidance) {
      guidance.textContent = SPEED_GUIDANCE[designStyle] ?? '';
      show(guidance);
    }
  }

  function applyLookbookPrefill() {
    const params = new URLSearchParams(window.location.search);
    const fallbackSlugs = readSlugFallback(params);
    const hasBoardFlag = params.get('inspiration_board') === '1' || fallbackSlugs.length > 0;
    if (hasBoardFlag) {
      const catalog = getLookbookCatalog();
      let boardItems = readSessionBoard();
      if (fallbackSlugs.length) {
        boardItems = fallbackSlugs
          .map((slug) => boardItems.find((item) => item.publicLookSlug === slug) ?? catalog.find((item) => item.publicLookSlug === slug) ?? null)
          .filter(Boolean) as LookbookInspiration[];
      }
      boardItems = boardItems.slice(0, 6);
      if (boardItems.length) {
        answers.lookbookInspirations = boardItems;
        answers.publicLookSlug = boardItems.map((item) => item.publicLookSlug).join(',');
        answers.publicLookTitle = boardItems.map((item) => item.publicTitle).join(', ');
        answers.lookbookCategory = Array.from(new Set(boardItems.map((item) => item.category).filter(Boolean))).join(', ');
        answers.inspirationImageId = answers.publicLookSlug;
        applyServicesFromLookbook(boardItems);
        applyDesignStyleFromLookbook(boardItems);
        renderLookbookBoardBanner(boardItems);
        return;
      }
    }

    const service = readSafeParam(params, 'service', 40) as Service;
    const designStyle = readSafeParam(params, 'design_style', 40) as Style;
    const slug = readSafeParam(params, 'public_look_slug', 80);
    const title = readSafeParam(params, 'public_look_title', 120);
    const category = readSafeParam(params, 'category', 80);
    const inspirationImageId = readSafeParam(params, 'inspiration_image_id', 80);
    const allowedServices: Service[] = ['face-painting', 'balloon-twisting', 'face-gems'];
    const allowedStyles: Style[] = ['quick-cheek-arm', 'standard-party', 'full-face', 'fast-event-menu', 'not-sure'];

    if (allowedServices.includes(service)) {
      answers.services = [service];
      answers.lookbookService = service;
      document.querySelectorAll<HTMLInputElement>('#step2-options input[type="checkbox"]').forEach((input) => {
        input.checked = input.value === service;
      });
      markOptionSelected('step2-options', service, true);
    }

    if (allowedStyles.includes(designStyle)) {
      answers.designStyle = designStyle;
      answers.lookbookDesignStyle = designStyle;
      const input = qs<HTMLInputElement>(`#step4-options input[value="${designStyle}"]`);
      if (input) input.checked = true;
      markOptionSelected('step4-options', designStyle);
      const guidance = qs('#step4-guidance');
      if (guidance) {
        guidance.textContent = SPEED_GUIDANCE[designStyle] ?? '';
        show(guidance);
      }
    }

    answers.publicLookSlug = slug;
    answers.publicLookTitle = title;
    answers.lookbookCategory = category;
    answers.inspirationImageId = inspirationImageId || slug;
    if (slug || title) {
      answers.lookbookInspirations = [
        {
          publicLookSlug: slug,
          publicTitle: title,
          service: service as LookbookInspiration['service'],
          serviceLabel: SERVICE_LABELS[service] ?? service,
          designStyle,
          designStyleLabel: designStyle,
          category,
          thumbnailSrc: '',
        },
      ].filter((item) => item.publicLookSlug && item.publicTitle && ['face-painting', 'balloon-twisting', 'face-gems'].includes(item.service));
    }

    const banner = qs<HTMLElement>('#lookbook-prefill-banner');
    if (banner && (title || answers.lookbookService)) {
      const label = title || SERVICE_LABELS[answers.lookbookService] || 'your selected look';
      banner.textContent = `Party Lookbook inspiration selected: ${label}. You can adjust every answer before sending your request.`;
      show(banner);
    }
  }

  // ── Helpers for capacity-aware UI ─────────────────────────────
  function getActualKidsCount(): number {
    return resolveKidsCount(answers.kidsCountBucket, answers.kidsCountActual);
  }

  function formatCents(cents: number): string {
    return `$${(cents / 100).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
  }

  // Badge label for a given duration option given current kids/style answers
  function getDurationBadge(durationMinutes: number): { label: string; cls: string } | null {
    if (!answers.kidsCountBucket && !answers.kidsCountActual) return null;
    const kidsCount = getActualKidsCount();
    const style = answers.designStyle ?? 'standard-party';
    const cap = calculateCapacity({ kidsCount, designStyle: style, bookedDurationMinutes: durationMinutes });

    if (cap.requiredArtistCount > 4) {
      return { label: 'Custom plan recommended', cls: 'wizard-badge-red' };
    }
    if (cap.requiredArtistCount > 1) {
      // Check if quick designs would fit with 1 artist
      const quickCap = calculateCapacity({ kidsCount, designStyle: 'quick-cheek-arm', bookedDurationMinutes: durationMinutes });
      if (quickCap.requiredArtistCount === 1) {
        return { label: 'Best with faster designs', cls: 'wizard-badge-amber' };
      }
      return { label: 'May need a second artist', cls: 'wizard-badge-amber' };
    }
    // 1 artist fits — check how comfortable
    const capacityRatio = cap.usableMinutesPerArtist / Math.max(1, cap.requiredArtistMinutes);
    const recMinutes = typeof recommendedDuration === 'number' ? recommendedDuration : null;
    if (recMinutes !== null && durationMinutes === recMinutes) {
      return { label: 'Best fit', cls: 'wizard-badge-green' };
    }
    if (capacityRatio < 1.05) {
      return { label: 'Too tight', cls: 'wizard-badge-amber' };
    }
    if (durationMinutes > (recMinutes ?? 0)) {
      return { label: 'More relaxed', cls: 'wizard-badge-blue' };
    }
    return { label: 'Best fit', cls: 'wizard-badge-green' };
  }

  function updateProgress(step: number) {
    const pct = Math.round((step / TOTAL_STEPS) * 100);
    const fill = qs<HTMLElement>('#wizard-progress-fill');
    const label = qs('#wizard-progress-label');
    const pctEl = qs('#wizard-progress-pct');
    const bar = qs('#wizard-progress-bar');
    if (fill) fill.style.width = `${pct}%`;
    if (label) label.textContent = `Step ${step} of ${TOTAL_STEPS}`;
    if (pctEl) pctEl.textContent = `${pct}%`;
    if (bar) bar.setAttribute('aria-valuenow', String(step));
  }

  function showStep(step: number) {
    // Hide all steps
    document.querySelectorAll<HTMLElement>('.wizard-step').forEach(el => {
      el.classList.remove('active');
    });
    // Show the target step
    const target = document.querySelector<HTMLElement>(`.wizard-step[data-wizard-step="${step}"]`);
    target?.classList.add('active');
    target?.scrollIntoView({ behavior: 'smooth', block: 'start' });

    // Nav visibility
    const nav = qs('#wizard-nav');
    const backBtn = qs<HTMLButtonElement>('#btn-back');

    // Steps 7 (recommendation) and 8 (contact details) hide the standard nav
    if (step === 7 || step === 8) {
      hide(nav);
    } else {
      show(nav);
    }
    if (backBtn) backBtn.disabled = step === 1;

    // Progress
    show(qs('#wizard-progress-wrapper'));
    updateProgress(step);

    // Clear validation error
    hide(qs('#wizard-validation-error'));
    persistWizardProgress();
  }

  // ── Option selection UI helpers ───────────────────────────────
  function markOptionSelected(containerId: string, value: string, multi = false) {
    const container = qs(`#${containerId}`);
    if (!container) return;
    container.querySelectorAll<HTMLElement>('.wizard-option').forEach(opt => {
      const v = opt.dataset.value;
      if (multi) {
        // For checkboxes, toggle selected based on actual checkbox state
        const cb = opt.querySelector<HTMLInputElement>('input[type="checkbox"]');
        opt.classList.toggle('selected', cb?.checked ?? false);
      } else {
        opt.classList.toggle('selected', v === value);
      }
    });
  }

  // ── Step 1 — Event Type ───────────────────────────────────────
  const STEP1_FEEDBACK: Record<string, string> = {
    'birthday-party':       "A birthday party — our favorite! Let's build your perfect plan.",
    'school-event':         "School events often call for a custom plan — we'll take great care of your students.",
    'corporate-family-day': "Corporate and family day events are our specialty — we'll make sure it runs beautifully.",
    'festival-community':   "Large community events get a custom plan so the entertainment keeps flowing.",
    'other':                "No problem — we'll figure out exactly what fits.",
  };

  qs('#step1-options')?.addEventListener('change', (e) => {
    const radio = e.target as HTMLInputElement;
    answers.eventType = radio.value as EventType;
    markOptionSelected('step1-options', radio.value);
    const fb = qs('#step1-feedback');
    if (fb) {
      fb.textContent = STEP1_FEEDBACK[radio.value] ?? '';
      show(fb);
    }
  });

  // ── Step 2 — Services ─────────────────────────────────────────
  qs('#step2-options')?.addEventListener('change', (e) => {
    const cb = e.target as HTMLInputElement;
    const val = cb.value as Service;

    if (val === 'not-sure') {
      // not-sure overrides all other selections
      if (cb.checked) {
        answers.services = ['not-sure'];
        document.querySelectorAll<HTMLInputElement>('#step2-options input[type="checkbox"]').forEach(input => {
          input.checked = input.value === 'not-sure';
        });
      } else {
        answers.services = answers.services.filter(s => s !== 'not-sure');
      }
    } else if (val === 'combo') {
      if (cb.checked) {
        answers.services = ['combo'];
        document.querySelectorAll<HTMLInputElement>('#step2-options input[type="checkbox"]').forEach(input => {
          input.checked = input.value === 'combo';
        });
      } else {
        answers.services = answers.services.filter(s => s !== 'combo');
      }
    } else {
      // Deselect not-sure and combo if a specific service is chosen
      if (cb.checked) {
        answers.services = answers.services.filter(s => s !== 'not-sure' && s !== 'combo');
        answers.services.push(val);
        document.querySelectorAll<HTMLInputElement>('#step2-options input[value="not-sure"], #step2-options input[value="combo"]').forEach(input => {
          input.checked = false;
        });
      } else {
        answers.services = answers.services.filter(s => s !== val);
      }
    }

    markOptionSelected('step2-options', val, true);

    const fb = qs('#step2-feedback');
    if (fb) {
      if (answers.services.includes('combo')) {
        fb.textContent = "Great choice — combos keep more guests entertained at once. We'll confirm the best combination in your quote.";
        show(fb);
      } else if (answers.services.includes('not-sure')) {
        fb.textContent = "No worries — we'll recommend what works best for your event.";
        show(fb);
      } else {
        hide(fb);
      }
    }
  });

  // ── Step 3 — Kids Count (range card + exact/estimated count) ───
  // Effective bucket for guidance: an entered exact count drives it; else range.
  function effectiveKidsBucketLocal(): Kids | null {
    return typeof answers.kidsCountActual === 'number' && answers.kidsCountActual > 0
      ? (bucketFromCount(answers.kidsCountActual) as Kids)
      : answers.kidsCountBucket;
  }

  function updateKidsGuidance() {
    const guidance = qs('#step3-guidance');
    if (guidance && answers.kidsCountBucket) {
      guidance.textContent = CAPACITY_GUIDANCE[answers.kidsCountBucket] ?? '';
      show(guidance);
    }
    const selling = qs('#step3-selling');
    if (selling) {
      const effBucket = effectiveKidsBucketLocal();
      const rec = getRecommendedDuration(effBucket, answers.designStyle ?? 'standard-party');
      const recLabel = formatDurationLabel(rec);
      selling.textContent = recLabel !== 'Not selected' && recLabel !== 'Custom plan'
        ? `Most parents with a similar group choose ${recLabel} and love the results.`
        : "A larger group may need a custom plan — a fast event menu, a longer service window, or an additional artist. We'll confirm the best setup before booking.";
      show(selling);
    }
  }

  qs('#step3-options')?.addEventListener('change', (e) => {
    const radio = e.target as HTMLInputElement;
    answers.kidsCountBucket = radio.value as Kids;
    // Reset exact count when bucket changes
    answers.kidsCountActual = null;
    const exactInput = qs<HTMLInputElement>('#field-kidsExact');
    if (exactInput) {
      exactInput.value = '';
      exactInput.placeholder = EXACT_PLACEHOLDER[radio.value] ?? 'e.g. 12';
    }
    markOptionSelected('step3-options', radio.value);

    const requiresExactCount = radio.value !== 'not-sure';
    const exactWrapper = qs('#step3-exact-count');
    const reqMark = qs('#step3-exact-required');
    const estimateHint = qs('#step3-estimate-hint');
    if (exactInput) exactInput.required = requiresExactCount;
    if (requiresExactCount) {
      show(exactWrapper);
      show(reqMark);
      show(estimateHint);
    } else {
      hide(exactWrapper);
      hide(reqMark);
      hide(estimateHint);
    }
    hide(qs('#step3-exact-error'));
    hide(qs('#step3-count-conflict'));

    updateKidsGuidance();
  });

  // Capture exact/estimated kids count for any range, with whole-number/range
  // validation and a friendly range/count mismatch correction.
  qs<HTMLInputElement>('#field-kidsExact')?.addEventListener('input', (e) => {
    const raw = (e.target as HTMLInputElement).value.trim();
    const errEl = qs('#step3-exact-error');
    const conflictEl = qs('#step3-count-conflict');
    const estimateHint = qs('#step3-estimate-hint');

    if (raw === '') {
      answers.kidsCountActual = null;
      hide(errEl); hide(conflictEl); show(estimateHint);
      updateKidsGuidance();
      return;
    }

    const n = Number(raw);
    if (!Number.isInteger(n) || n < 1 || n > 200) {
      answers.kidsCountActual = null;
      if (errEl) { errEl.textContent = 'Please enter a whole number of children between 1 and 200.'; show(errEl); }
      hide(conflictEl); hide(estimateHint);
      updateKidsGuidance();
      return;
    }

    answers.kidsCountActual = n;
    hide(errEl); hide(estimateHint);

    // Do not silently accept a count that conflicts with the chosen range.
    const selected = answers.kidsCountBucket;
    const derived = bucketFromCount(n) as Kids;
    if (conflictEl && selected && selected !== 'not-sure' && derived !== selected) {
      conflictEl.textContent =
        `That number looks closer to ${KIDS_LABELS[derived]}. We'll use ${n} children for the recommendation.`;
      show(conflictEl);
    } else {
      hide(conflictEl);
    }

    updateKidsGuidance();
  });

  // ── Step 4 — Design Style ─────────────────────────────────────
  qs('#step4-options')?.addEventListener('change', (e) => {
    const radio = e.target as HTMLInputElement;
    answers.designStyle = radio.value as Style;
    markOptionSelected('step4-options', radio.value);

    const guidance = qs('#step4-guidance');
    if (guidance) {
      guidance.textContent = SPEED_GUIDANCE[radio.value as Style] ?? '';
      show(guidance);
    }
  });

  // ── Step 5 — Duration (pre-selection runs on entering the step) ──
  function initDurationStep() {
    // An exact/estimated child count drives the recommendation via its range.
    const effBucket = effectiveKidsBucketLocal();
    recommendedDuration = getRecommendedDuration(effBucket, answers.designStyle);
    const customPlanRecommended = recommendedDuration === 'custom';

    // Update subheading
    const subheading = qs('#step5-subheading');
    if (subheading) {
      const kLabel = typeof answers.kidsCountActual === 'number'
        ? `${answers.kidsCountActual} children`
        : (effBucket ? KIDS_LABELS[effBucket] : 'your group');
      const dLabel = answers.designStyle?.replace(/-/g, ' ') ?? 'your design choice';
      const recLabel = formatDurationLabel(recommendedDuration);
      if (customPlanRecommended) {
        subheading.textContent =
          `Choose the service window you have in mind for ${kLabel} — we'll plan around it.`;
      } else if (recLabel !== 'Not selected') {
        subheading.textContent =
          `Based on ${kLabel} and ${dLabel}, we recommend ${recLabel}. You can adjust if your party window is different.`;
      }
    }

    // Custom-plan planning recommendation — informational only; never forces
    // or promotes the long custom window or 'recommend a time' option.
    const planningNote = qs('#step5-planning-note');
    if (planningNote) {
      if (customPlanRecommended) {
        const largeEvent = effBucket === '40-plus';
        planningNote.innerHTML = largeEvent
          ? '<strong>Large-event custom plan recommended.</strong> For more than 40 children we build a ' +
            'custom entertainment plan — often with a second artist or a faster design menu — before ' +
            "confirming availability. Pick the window you have in mind and we'll plan around it."
          : '<strong>Custom plan recommended.</strong> For this group size and design style, we may ' +
            'recommend a second artist, a longer service window, or a faster design menu before ' +
            "confirming availability. Pick the window you have in mind and we'll plan around it.";
        show(planningNote);
      } else {
        hide(planningNote);
      }
    }

    // Show capacity-aware badge on each duration option
    ['60','90','120','180','240','custom','recommend'].forEach(v => {
      const badge = qs(`#badge-${v}`);
      if (!badge) return;
      if (v === 'recommend') {
        // 'Not sure — recommend a time for me' surfaces the engine's suggested
        // window so the customer knows what they'll get. Hidden when the
        // suggestion is itself a custom plan.
        if (typeof recommendedDuration === 'number') {
          badge.textContent = `We suggest ${formatDurationLabel(recommendedDuration)}`;
          badge.className = 'wizard-recommended-badge wizard-badge-green';
          show(badge);
        } else {
          hide(badge);
        }
        return;
      }
      const durationMin = v === 'custom' ? null : parseInt(v, 10);
      if (durationMin === null) {
        // '5+ hours / full event coverage' is a long custom window — never
        // auto-promoted as a best fit; the custom-plan note covers it instead.
        hide(badge);
        return;
      }
      // Capacity-aware badge for numeric durations
      const badgeInfo = getDurationBadge(durationMin);
      if (badgeInfo) {
        badge.textContent = badgeInfo.label;
        badge.className = `wizard-recommended-badge ${badgeInfo.cls}`;
        show(badge);
      } else {
        // Fall back to simple recommended badge if no capacity data yet
        const matches = recommendedDuration !== null && String(recommendedDuration) === v;
        if (matches) {
          badge.textContent = 'Recommended';
          badge.className = 'wizard-recommended-badge';
          show(badge);
        } else {
          hide(badge);
        }
      }
    });

    // Pre-select the recommended option if nothing is selected yet.
    // Only numeric recommendations pre-select; a custom-plan recommendation
    // never auto-selects the long custom window or the 'recommend a time'
    // option — the customer chooses their own requested window.
    const recForSelect = recommendedDuration;
    if (answers.selectedDurationOption === null && typeof recForSelect === 'number') {
      const input = document.querySelector<HTMLInputElement>(
        `#step5-options input[value="${recForSelect}"]`
      );
      if (input) {
        input.checked = true;
        answers.selectedDurationOption = DURATION_VALUES[String(recForSelect)] ?? null;
        markOptionSelected('step5-options', String(recForSelect));
      }
    }

    updateBadgeNote();
  }

  // Item 4: explain a conditional (amber/red) badge for the currently selected
  // window so a caution badge never silently undermines confidence. Reassuring
  // 'Best fit' / 'More relaxed' badges need no caveat.
  function updateBadgeNote() {
    const note = qs('#step5-badge-note');
    if (!note) return;
    const sel = answers.selectedDurationOption;
    if (typeof sel !== 'number') {
      // 'custom' / 'recommend' are explained by the planning note / suggestion badge
      hide(note);
      return;
    }
    const badgeInfo = getDurationBadge(sel);
    if (!badgeInfo || badgeInfo.cls === 'wizard-badge-green' || badgeInfo.cls === 'wizard-badge-blue') {
      hide(note);
      return;
    }
    const selLabel = formatDurationLabel(sel);
    let msg: string;
    if (badgeInfo.label === 'May need a second artist') {
      msg = `Heads up: for your group size and design style, ${selLabel} may need a second artist to keep a comfortable pace. We'll confirm staffing in your quote.`;
    } else if (badgeInfo.label === 'Best with faster designs') {
      msg = `Heads up: ${selLabel} fits best with quicker designs for your group size. A fast event menu helps keep the line moving.`;
    } else if (badgeInfo.label === 'Too tight') {
      msg = `Heads up: ${selLabel} may feel tight for your group size and design style. A longer window or faster designs gives a more comfortable pace.`;
    } else if (badgeInfo.label === 'Custom plan recommended') {
      msg = `For your group size and design style, ${selLabel} needs a custom plan — possibly a second artist or a faster design menu. We'll plan it with you.`;
    } else {
      msg = `For ${selLabel}, final capacity depends on design style, time window, and staffing. We'll confirm in your quote.`;
    }
    note.textContent = msg;
    show(note);
  }

  qs('#step5-options')?.addEventListener('change', (e) => {
    const radio = e.target as HTMLInputElement;
    if (radio.value === 'recommend') {
      // Adopt the engine's recommendation: numeric where one exists, otherwise
      // a custom plan. Never leaves the selection ambiguous or null.
      answers.selectedDurationOption = typeof recommendedDuration === 'number'
        ? recommendedDuration
        : 'custom';
    } else {
      answers.selectedDurationOption = DURATION_VALUES[radio.value] ?? null;
    }
    markOptionSelected('step5-options', radio.value);
    updateConflictWarning();
    updateBadgeNote();
  });

  function updateConflictWarning() {
    const warning = qs('#step5-conflict');
    if (!warning) return;
    const kLabel = answers.kidsCountBucket ? KIDS_LABELS[answers.kidsCountBucket] : 'your group';
    const selLabel = formatDurationLabel(answers.selectedDurationOption);
    const recLabel = formatDurationLabel(recommendedDuration);
    const msg = getConflictWarning(answers.selectedDurationOption, recommendedDuration, kLabel, selLabel, recLabel);
    if (msg) {
      warning.textContent = msg;
      show(warning);
    } else {
      hide(warning);
    }
  }

  // ── Step 6 — Date / Time / Location ───────────────────────────
  function bindField(id: string, key: keyof typeof answers, transform?: (v: string) => unknown) {
    qs<HTMLInputElement>(`#field-${id}`)?.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      (answers as unknown as Record<string, unknown>)[key] = transform ? transform(val) : val;
    });
  }
  bindField('eventDate', 'eventDate', (v) => v || null);
  bindField('eventTime', 'eventTime', (v) => v || null);
  bindField('eventCity', 'eventCity');
  bindField('venueName', 'venueName');
  bindField('specialRequests', 'specialRequests');

  // Travel band select → travelMiles
  qs<HTMLSelectElement>('#field-travelBand')?.addEventListener('change', (e) => {
    const val = (e.target as HTMLSelectElement).value;
    answers.travelMiles = val ? parseInt(val, 10) : null;
  });

  // ── Step 7 — Recommendation ────────────────────────────────────
  function buildSummaryRow(label: string, value: string): HTMLElement {
    const row = document.createElement('div');
    row.className = 'wizard-summary-row';
    row.innerHTML = `<span class="wizard-summary-label">${label}</span><span class="wizard-summary-value">${value}</span>`;
    return row;
  }

  // Item 5/6: render a clear, consistent plan summary across every result
  // variant — event, services, guest count, design style, service window,
  // travel bucket, optional artist count, date/location, and the quote outcome.
  function appendPlanSummary(
    rowsEl: Element,
    opts: { durationLabel: string; outcomeLabel: string; artistCount?: number },
  ) {
    rowsEl.innerHTML = '';
    if (answers.eventType) rowsEl.appendChild(buildSummaryRow('Event', EVENT_LABELS[answers.eventType] ?? answers.eventType));
    if (answers.services.length) rowsEl.appendChild(buildSummaryRow('Services', answers.services.map(s => SERVICE_LABELS[s] ?? s).join(', ')));
    // Show the exact count when entered; mark it "estimated" when it was a
    // not-sure range or it differs from the selected range. Never bucket-only
    // once an exact count exists.
    let kidsLabel = '';
    if (typeof answers.kidsCountActual === 'number') {
      const selected = answers.kidsCountBucket;
      const derived = bucketFromCount(answers.kidsCountActual) as Kids;
      const estimated = selected === 'not-sure' || (!!selected && derived !== selected);
      kidsLabel = `${answers.kidsCountActual}${estimated ? ' estimated' : ''}`;
    } else if (answers.kidsCountBucket) {
      kidsLabel = KIDS_LABELS[answers.kidsCountBucket] ?? answers.kidsCountBucket;
    }
    if (kidsLabel) rowsEl.appendChild(buildSummaryRow('Children', kidsLabel));
    if (answers.designStyle) rowsEl.appendChild(buildSummaryRow('Design style', STYLE_LABELS[answers.designStyle] ?? answers.designStyle));
    if (opts.durationLabel && opts.durationLabel !== 'Not selected') {
      rowsEl.appendChild(buildSummaryRow('Service window', opts.durationLabel));
    }
    if (typeof opts.artistCount === 'number') rowsEl.appendChild(buildSummaryRow('Artists needed', `${opts.artistCount}`));
    if (answers.travelMiles !== null) {
      rowsEl.appendChild(buildSummaryRow('Travel', TRAVEL_BAND_LABELS[answers.travelMiles] ?? `${answers.travelMiles} miles`));
    }
    if (answers.eventDate) rowsEl.appendChild(buildSummaryRow('Date', `${answers.eventDate}${answers.eventTime ? ' at ' + answers.eventTime : ''}`));
    if (answers.eventCity) rowsEl.appendChild(buildSummaryRow('Location', answers.eventCity));
    rowsEl.appendChild(buildSummaryRow('Quote outcome', opts.outcomeLabel));
  }

  // Current eligibility result — populated by renderRecommendation, read by wireStep7Cta
  let currentEligibility: ReturnType<typeof assessEligibility> | null = null;
  let currentAvailabilityStatus: 'confirmed' | 'pending_artist_confirmation' | 'unknown' = 'unknown';
  let currentClassification: ReturnType<typeof classifyQuoteOutcome> | null = null;

  async function renderRecommendation() {
    const rec = computeRecommendation(answers as Parameters<typeof computeRecommendation>[0]);

    // Compute capacity and eligibility for R8
    const durationMin = typeof answers.selectedDurationOption === 'number'
      ? answers.selectedDurationOption
      : 120; // fallback for 'custom' selection
    const kidsCount = getActualKidsCount();
    const capacity = calculateCapacity({
      kidsCount,
      designStyle: answers.designStyle ?? 'standard-party',
      bookedDurationMinutes: durationMin,
    });
    const eligibility = assessEligibility({
      eventType: answers.eventType ?? '',
      services: answers.services as string[],
      kidsCount,
      designStyle: answers.designStyle ?? 'standard-party',
      durationMinutes: durationMin,
      travelMiles: answers.travelMiles ?? 0,
      capacityResult: capacity,
    });
    currentEligibility = eligibility;
    currentAvailabilityStatus = 'unknown';

    try {
      const res = await fetch('/api/booking-eligibility', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          eventType: answers.eventType ?? '',
          services: answers.services,
          kidsCountBucket: answers.kidsCountBucket ?? '',
          kidsCountActual: answers.kidsCountActual,
          designStyle: answers.designStyle ?? '',
          durationMinutes: durationMin,
          travelMiles: answers.travelMiles ?? 0,
          eventDate: answers.eventDate,
          startTime: answers.eventTime,
        }),
      });
      const data = await res.json() as {
        ok?: boolean;
        pricing?: typeof eligibility.pricing;
        availability?: { status?: string; paymentAllowed?: boolean };
      };
      if (res.ok && data.ok && data.availability?.status === 'confirmed' && data.availability.paymentAllowed === true) {
        currentAvailabilityStatus = 'confirmed';
      } else if (
        res.ok &&
        data.ok &&
        data.availability?.status === 'pending_artist_confirmation' &&
        data.availability.paymentAllowed === true
      ) {
        currentAvailabilityStatus = 'pending_artist_confirmation';
      }
    } catch {
      currentAvailabilityStatus = 'unknown';
    }

    const fastEl = qs('#rec-fast');
    const customEl = qs('#rec-custom');

    // Classify the outcome as exactly one of: instant quote eligible,
    // manual approval required, custom quote required, unavailable/no checkout.
    const classification = classifyQuoteOutcome({
      eligibilityStatus: eligibility.status,
      reasons: eligibility.reasons,
      travelMiles: answers.travelMiles ?? 0,
      availabilityConfirmed: currentAvailabilityStatus === 'confirmed',
      conditionalHoldAvailable: currentAvailabilityStatus === 'pending_artist_confirmation',
      customPlanReason: rec.customQuoteTrigger ?? null,
    });
    currentClassification = classification;

    if (classification === 'instant-quote-eligible' && eligibility.pricing) {
      // ── Instant-book eligible with server-confirmed availability: show pricing + Stripe button ─────
      show(fastEl);
      hide(customEl);

      // Summary rows
      const rowsEl = qs('#rec-summary-rows');
      if (rowsEl) appendPlanSummary(rowsEl, {
        durationLabel: formatDurationLabel(answers.selectedDurationOption),
        outcomeLabel: CLASSIFICATION_LABELS['instant-quote-eligible'],
        artistCount: capacity.requiredArtistCount,
      });

      const sellingEl = qs('#rec-selling-copy');
      if (sellingEl) sellingEl.textContent = rec.sellingCopy;

      const conflictEl = qs('#rec-conflict-warning');
      if (conflictEl) hide(conflictEl);

      // Show pricing panel, hide standard notice
      const panel = qs('#rec-pricing-panel');
      const notice = qs('#rec-standard-notice');
      show(panel);
      hide(notice);

      const { eventTotalCents, retainerCents, pricingModel } = eligibility.pricing;
      const priceEl = qs('#rec-price-display');
      const retainerEl = qs('#rec-retainer-display');
      const detailEl = qs('#rec-pricing-detail');
      if (priceEl) priceEl.textContent = formatCents(eventTotalCents);
      if (retainerEl) retainerEl.textContent = formatCents(retainerCents);
      if (detailEl) {
        const modelNote = pricingModel === 'fixed-package' ? 'Fixed package price' : 'Hourly rate';
        const travelNote = eligibility.pricing.travelFeeCents > 0 ? ` · Travel fee: ${formatCents(eligibility.pricing.travelFeeCents)}` : '';
        detailEl.textContent = `${modelNote} · ${capacity.requiredArtistCount} artist${capacity.requiredArtistCount > 1 ? 's' : ''}${travelNote}`;
      }
    } else if (classification === 'unavailable-no-checkout') {
      // ── Availability not server-confirmed: no checkout offered ───
      show(fastEl);
      hide(customEl);

      const rowsEl = qs('#rec-summary-rows');
      if (rowsEl) appendPlanSummary(rowsEl, {
        durationLabel: formatDurationLabel(answers.selectedDurationOption) !== 'Not selected'
          ? formatDurationLabel(answers.selectedDurationOption)
          : rec.recommendedDurationLabel,
        outcomeLabel: CLASSIFICATION_LABELS['unavailable-no-checkout'],
      });

      const sellingEl = qs('#rec-selling-copy');
      if (sellingEl) sellingEl.textContent = rec.sellingCopy;

      const conflictEl = qs('#rec-conflict-warning');
      if (conflictEl) {
        if (rec.conflictWarning) { conflictEl.textContent = rec.conflictWarning; show(conflictEl); }
        else { hide(conflictEl); }
      }

      // Show standard notice, hide pricing panel. Option A: availability is unknown,
      // so online retainer checkout remains unavailable.
      hide(qs('#rec-pricing-panel'));
      show(qs('#rec-standard-notice'));
    } else {
      // ── Manual approval required or custom quote required: no checkout ──
      hide(fastEl);
      show(customEl);

      const classificationEl = qs('#rec-classification');
      if (classificationEl) classificationEl.textContent = CLASSIFICATION_LABELS[classification];

      const customCopyEl = qs('#rec-custom-copy');
      if (customCopyEl) customCopyEl.textContent = CUSTOM_PLAN_COPY;

      // Customer-safe context for the specific scenario. Internal eligibility
      // reason codes are never rendered.
      const contextEl = qs('#rec-custom-context');
      if (contextEl) {
        if (rec.customQuoteCopy) { contextEl.textContent = rec.customQuoteCopy; show(contextEl); }
        else { hide(contextEl); }
      }

      const customRowsEl = qs('#rec-custom-summary-rows');
      if (customRowsEl) appendPlanSummary(customRowsEl, {
        durationLabel: formatDurationLabel(answers.selectedDurationOption) !== 'Not selected'
          ? formatDurationLabel(answers.selectedDurationOption)
          : rec.recommendedDurationLabel,
        outcomeLabel: CLASSIFICATION_LABELS[classification],
      });
    }
  }

  // CTA buttons on step 7 (recommendation screen)
  // "Request This Quote" → advance to step 8
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.id === 'btn-edit-answers') {
      // Return to the most recent answer step (date/time/location) so the
      // customer can revise without restarting from Step 1. Back still walks
      // through every earlier step with all answers preserved.
      currentStep = 6;
      showStep(6);
    }
  });

  // Step 7 uses its own CTA — wire it after the recommendation panel is shown
  function wireStep7Cta() {
    // Wire Stripe "Reserve" button (only visible for instant-book eligible events)
    const stripeBtn = qs<HTMLButtonElement>('#btn-stripe-reserve');
    if (stripeBtn && !stripeBtn.dataset.wired) {
      stripeBtn.dataset.wired = '1';
      stripeBtn.addEventListener('click', handleStripeReserve);
    }

    // Add "Request Quote" / "Request Custom Plan" CTA to non-eligible panels
    for (const id of ['rec-fast', 'rec-custom']) {
      const panel = qs(`#${id}`);
      if (!panel || panel.querySelector('.wizard-step7-cta')) continue;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'wizard-step7-cta mt-5 rounded-xl bg-orange-500 px-6 py-3 text-sm font-semibold text-white hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:ring-offset-2 transition-colors';
      btn.textContent = id === 'rec-fast' ? 'Request This Quote →' : 'Request My Custom Plan →';
      btn.setAttribute('aria-label', id === 'rec-fast' ? 'Request this quote' : 'Request a custom plan');
      btn.addEventListener('click', () => {
        currentStep = 8;
        showStep(8);
      });
      panel.appendChild(btn);
    }
  }

  async function handleStripeReserve() {
    const btn = qs<HTMLButtonElement>('#btn-stripe-reserve');
    if (!btn) return;
    if (!currentEligibility || currentEligibility.status !== 'instant-book') return;
    if (currentAvailabilityStatus !== 'confirmed' && currentAvailabilityStatus !== 'pending_artist_confirmation') return;
    if (currentClassification !== 'instant-quote-eligible') return;

    btn.disabled = true;
    btn.textContent = 'Preparing secure checkout…';

    const durationMin = typeof answers.selectedDurationOption === 'number'
      ? answers.selectedDurationOption : 120;

    try {
      const res = await fetch('/api/create-checkout-session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          eventType: answers.eventType ?? '',
          services: answers.services,
          kidsCountBucket: answers.kidsCountBucket ?? '',
          kidsCountActual: answers.kidsCountActual,
          designStyle: answers.designStyle ?? '',
          durationMinutes: durationMin,
          travelMiles: answers.travelMiles ?? 0,
          eventDate: answers.eventDate,
          eventTime: answers.eventTime,
          eventCity: answers.eventCity,
          customerEmail: answers.email || undefined,
        }),
      });
      const data = await res.json() as { ok: boolean; checkoutUrl?: string; error?: string };

      if (!res.ok || !data.ok || !data.checkoutUrl) {
        throw new Error(data.error ?? 'Checkout session could not be created');
      }

      // Redirect to Stripe hosted checkout
      window.location.href = data.checkoutUrl;
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
      const errEl = qs('#wizard-validation-error');
      if (errEl) { errEl.textContent = msg; show(errEl); }
      btn.disabled = false;
      btn.textContent = 'Place 20% Availability Hold →';
    }
  }

  // ── Step 8 — Quote Request Form ───────────────────────────────
  qs<HTMLInputElement>('#field-firstName')?.addEventListener('input', (e) => { answers.firstName = (e.target as HTMLInputElement).value; });
  qs<HTMLInputElement>('#field-lastName')?.addEventListener('input', (e) => { answers.lastName = (e.target as HTMLInputElement).value; });
  qs<HTMLInputElement>('#field-email')?.addEventListener('input', (e) => { answers.email = (e.target as HTMLInputElement).value; });
  qs<HTMLInputElement>('#field-phone')?.addEventListener('input', (e) => { answers.phone = (e.target as HTMLInputElement).value; });
  qs<HTMLSelectElement>('#field-contact-method')?.addEventListener('change', (e) => { answers.preferredContactMethod = (e.target as HTMLSelectElement).value as PreferredContactMethod; });

  // First-touch attribution capture (Plan My Party lead-data completeness): record
  // gclid/utm/source_page on load so they survive to submission.
  try {
    const ap = new URLSearchParams(location.search);
    const cur = JSON.parse(sessionStorage.getItem('hfla_attribution') || '{}') as Record<string, string>;
    let changed = false;
    for (const k of ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'gclid', 'fbclid', 'msclkid']) {
      const v = ap.get(k);
      if (v && !cur[k]) { cur[k] = v; changed = true; }
    }
    if (!cur.source_page) { cur.source_page = location.pathname; changed = true; }
    if (changed) sessionStorage.setItem('hfla_attribution', JSON.stringify(cur));
  } catch {}

  qs('#wizard-quote-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const { valid, errors } = validateStep(8, answers as Parameters<typeof validateStep>[1]);
    if (!valid) {
      const errEl = qs('#step8-error');
      if (errEl) { errEl.textContent = errors.join(' '); show(errEl); }
      return;
    }
    hide(qs('#step8-error'));

    const submitBtn = qs<HTMLButtonElement>('#btn-submit-quote');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending your request…'; }
    hide(qs('#step8-fallback-cta'));

    // Check honeypot
    const honeypot = (qs<HTMLInputElement>('#wizard-quote-form input[name="honeypot"]'))?.value?.trim() ?? '';
    if (honeypot !== '') {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send My Quote Request →'; }
      return;
    }

    // Build payload — NO internal fields, NO Stripe credentials
    const rec = computeRecommendation(answers as Parameters<typeof computeRecommendation>[0]);
    const payload = {
      eventType: answers.eventType ?? '',
      services: answers.services,
      kidsCountBucket: answers.kidsCountBucket ?? '',
      kidsCountActual: answers.kidsCountActual ?? null,
      designStyle: answers.designStyle ?? '',
      selectedDurationMinutes: answers.selectedDurationOption,
      recommendedDurationMinutes: rec.recommendedDuration,
      branch: rec.branch,
      eventDate: answers.eventDate,
      eventTime: answers.eventTime,
      eventCity: answers.eventCity,
      venueName: answers.venueName || null,
      travelMiles: answers.travelMiles ?? null,
      firstName: answers.firstName,
      lastName: answers.lastName,
      email: answers.email,
      phone: answers.phone || null,
      specialRequests: answers.specialRequests || null,
      service: answers.lookbookService || null,
      design_style: answers.lookbookDesignStyle || null,
      public_look_slug: answers.publicLookSlug || null,
      public_look_title: answers.publicLookTitle || null,
      category: answers.lookbookCategory || null,
      inspiration_image_id: answers.inspirationImageId || null,
      quoteOutcome: currentClassification,
      quoteRequestIdempotencyKey: getQuoteRequestIdempotencyKey(),
      consentAcknowledgement: true,
      lookbook_inspirations: answers.lookbookInspirations.map((item) => ({
        public_look_slug: item.publicLookSlug,
        public_look_title: item.publicTitle,
        service: item.service,
        design_style: item.designStyle,
        category: item.category || null,
      })),
      wizardVersion: 'guided-wizard-v1',
      submittedAt: new Date().toISOString(),
      preferredContactMethod: answers.preferredContactMethod || 'any',
      ...(() => {
        let stored: Record<string, string> = {};
        try { stored = JSON.parse(sessionStorage.getItem('hfla_attribution') || '{}'); } catch {}
        const ap = new URLSearchParams(location.search);
        const pick = (k: string) => ap.get(k) || stored[k] || null;
        return {
          source_page: location.pathname || stored.source_page || null,
          utm_source: pick('utm_source'),
          utm_medium: pick('utm_medium'),
          utm_campaign: pick('utm_campaign'),
          utm_term: pick('utm_term'),
          utm_content: pick('utm_content'),
          gclid: pick('gclid'),
          fbclid: pick('fbclid'),
          msclkid: pick('msclkid'),
        };
      })(),
    };

    try {
      const res = await fetch('/api/quote-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json() as {
        ok: boolean;
        received?: boolean;
        persisted?: boolean;
        leadId?: string;
        message: string;
      };
      if (!res.ok || !data.ok || data.received !== true || data.persisted !== true) {
        throw new Error(data.message ?? 'Submission failed');
      }
      track('hfla_quote_submit', {
        source: answers.lookbookInspirations.length ? 'party_lookbook' : 'wizard',
        public_look_slug: answers.publicLookSlug || undefined,
        inspiration_count: answers.lookbookInspirations.length || undefined,
      });
      showConfirmation(data.leadId);
    } catch (err) {
      const errEl = qs('#step8-error');
      if (errEl) {
        const msg = err instanceof Error && err.message
          ? err.message
          : 'We could not submit your request. Please call/text 818-619-5506.';
        errEl.textContent = msg.includes('call/text')
          ? msg
          : 'We could not submit your request. Please call/text 818-619-5506.';
        show(errEl);
      }
      show(qs('#step8-fallback-cta'));
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send My Quote Request →'; }
    }
  });

  function showConfirmation(leadId?: string) {
    clearWizardProgress();
    hide(qs('#wizard-steps-container'));
    hide(qs('#wizard-nav'));
    hide(qs('#wizard-progress-wrapper'));
    hide(qs('#wizard-validation-error'));
    const conf = qs('#wizard-confirmation');
    if (conf) {
      const nameEl = qs('#wizard-confirm-name');
      if (nameEl) {
        nameEl.textContent =
          `Thank you, ${answers.firstName}! Your party plan request was received. ` +
          `Happy Faces LA will review it and follow up about availability and your official quote.`;
      }
      const referenceEl = qs('#wizard-confirm-reference');
      if (referenceEl) {
        if (leadId) {
          referenceEl.textContent = `Reference: ${leadId}`;
          show(referenceEl);
        } else {
          hide(referenceEl);
        }
      }
      const emailEl = qs('#wizard-confirm-email');
      if (emailEl) {
        emailEl.textContent = 'Not confirmed yet — booking is confirmed only after Happy Faces LA sends confirmation.';
      }
      show(conf);
    }
  }

  // "Plan Another Party" resets the wizard
  qs('#btn-plan-another')?.addEventListener('click', () => {
    clearWizardProgress();
    window.location.reload();
  });

  // ── Navigation ────────────────────────────────────────────────
  qs('#btn-next')?.addEventListener('click', async () => {
    const { valid, errors } = validateStep(currentStep, answers as Parameters<typeof validateStep>[1]);
    if (!valid) {
      const errEl = qs('#wizard-validation-error');
      if (errEl) { errEl.textContent = errors.join(' '); show(errEl); }
      return;
    }
    hide(qs('#wizard-validation-error'));

    // Special hooks before advancing
    if (currentStep === 4) {
      // Reset duration selection so step 5 can pre-select freshly
      answers.selectedDurationOption = null;
      document.querySelectorAll<HTMLInputElement>('#step5-options input[type="radio"]').forEach(r => { r.checked = false; });
      document.querySelectorAll('.wizard-option[data-wizard-step] .wizard-option').forEach(o => o.classList.remove('selected'));
    }
    if (currentStep === 5) {
      initDurationStep(); // updates badges/subheading; no-op if already done
    }
    if (currentStep === 6) {
      // Validate date not in past
      if (answers.eventDate && isDateInPast(answers.eventDate)) {
        const errEl = qs('#wizard-validation-error');
        if (errEl) { errEl.textContent = 'Please choose a future date for your event.'; show(errEl); }
        return;
      }
      await renderRecommendation();
      wireStep7Cta();
    }

    currentStep++;
    showStep(currentStep);

    // After advancing to step 5, initialize the duration recommendations
    if (currentStep === 5) {
      initDurationStep();
    }
  });

  qs('#btn-back')?.addEventListener('click', () => {
    if (currentStep <= 1) return;
    currentStep--;
    showStep(currentStep);
  });

  // Item 9: Step 8 has no standard nav, so give it its own visible Back control
  // that returns to the plan summary (Step 7) without losing any answers.
  qs('#btn-step8-back')?.addEventListener('click', () => {
    currentStep = 7;
    showStep(7);
  });

  // Item 8: clear a lingering step error the moment the customer changes any
  // selection or field on the current step.
  const stepsContainer = qs('#wizard-steps-container');
  stepsContainer?.addEventListener('change', clearValidationError);
  stepsContainer?.addEventListener('input', clearValidationError);
  stepsContainer?.addEventListener('change', persistWizardProgress);
  stepsContainer?.addEventListener('input', persistWizardProgress);

  async function initWizard() {
    if (initialized) return;
    initialized = true;
    restoreWizardProgress();
    applyLookbookPrefill();
    hydrateWizardControls();
    track('hfla_quote_start', {
      source: answers.lookbookInspirations.length ? 'party_lookbook' : 'wizard',
      public_look_slug: answers.publicLookSlug || undefined,
      inspiration_count: answers.lookbookInspirations.length || undefined,
    });
    if (currentStep >= 5) {
      initDurationStep();
    }
    if (currentStep >= 7) {
      await renderRecommendation();
      wireStep7Cta();
    }
    showStep(currentStep);
  }

  // ── Initialize ────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', initWizard);

  // Fallback if DOMContentLoaded already fired
  if (document.readyState !== 'loading') {
    initWizard();
  }
</script>
