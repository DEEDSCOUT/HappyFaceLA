---
import { business } from "../../data/business";
import { navigation } from "../../data/navigation";
---

<header class="sticky top-0 z-50 border-b border-orange-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a class="flex items-center" href="/" aria-label={business.name}>
      <img
        src="/images/happy-faces-la-logo.png"
        alt={`${business.name} logo`}
        width="120"
        height="120"
        class="h-14 w-auto"
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <nav class="hidden items-center gap-4 md:flex">
      {navigation.desktop.map((item) => (
        <a class="text-sm font-medium text-slate-700 hover:text-orange-600" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a
      class="rounded-full bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600"
      href={`tel:${business.phone}`}
      data-track-event="phone_click"
    >
      Call/Text {business.displayPhone}
    </a>
  </div>

  <nav class="mx-auto flex w-full max-w-6xl gap-3 overflow-x-auto px-4 pb-3 md:hidden">
    {navigation.mobile.map((item) => (
      <a class="whitespace-nowrap text-sm font-medium text-slate-700" href={item.href}>{item.label}</a>
    ))}
  </nav>
</header>
