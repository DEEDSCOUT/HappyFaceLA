---
import { business } from "../../data/business";
import JsonLd from "./JsonLd.astro";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonicalPath,
  image = "/images/services/happy-faces-la-face-painting-service.webp",
  noindex = false,
  jsonLd = [],
} = Astro.props;

const canonical = new URL(canonicalPath, business.url).toString();
const ogImage = new URL(image, business.url).toString();
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
<link rel="apple-touch-icon" sizes="192x192" href="/favicon-192.png" />
<link rel="icon" href="/favicon.ico" />
<link rel="canonical" href={canonical} />

<title>{title}</title>

<meta property="og:type" content="website" />
<meta property="og:site_name" content={business.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{jsonLd.map((item) => <JsonLd data={item} />)}
