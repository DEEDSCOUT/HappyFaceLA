---
const currentPath = Astro.url.pathname;
---

<form data-quote-form data-source-page={currentPath} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="text-2xl font-bold text-slate-900">Request My Quote</h2>
  <p class="mt-2 text-sm text-slate-600">Share your event details and we will follow up quickly.</p>

  <div class="mt-5 grid gap-4 md:grid-cols-2">
    <label class="text-sm font-medium text-slate-700">First name<input required name="first_name" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Last name<input required name="last_name" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Phone<input required name="phone" type="tel" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Email<input required name="email" type="email" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Event date<input required name="event_date" type="date" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Start time<input required name="event_start_time" type="time" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Event city<input required name="event_city" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Address / cross streets (optional)<input name="event_address_or_cross_streets_optional" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Event type<input required name="event_type" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Estimated guest count<input required name="estimated_guest_count" type="number" min="1" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Children count (optional)<input name="children_count_optional" type="number" min="0" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
    <label class="text-sm font-medium text-slate-700">Budget range<input name="budget_range" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" /></label>
  </div>

  <fieldset class="mt-4">
    <legend class="text-sm font-medium text-slate-700">Services requested</legend>
    <div class="mt-2 flex flex-wrap gap-3 text-sm text-slate-700">
      <label><input type="checkbox" name="services_requested[]" value="Face Painting" /> Face painting</label>
      <label><input type="checkbox" name="services_requested[]" value="Balloon Twisting" /> Balloon twisting</label>
      <label><input type="checkbox" name="services_requested[]" value="Glitter Tattoos" /> Glitter tattoos</label>
      <label><input type="checkbox" name="services_requested[]" value="Face Gems" /> Face gems</label>
    </div>
  </fieldset>

  <label class="mt-4 block text-sm font-medium text-slate-700">Message<textarea name="message" rows="4" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2"></textarea></label>

  <input type="hidden" name="source_page" value={currentPath} />
  <input type="hidden" name="utm_source" />
  <input type="hidden" name="utm_medium" />
  <input type="hidden" name="utm_campaign" />
  <input type="hidden" name="utm_term" />
  <input type="hidden" name="utm_content" />
  <input type="hidden" name="gclid" />
  <input type="hidden" name="fbclid" />
  <input type="hidden" name="msclkid" />
  <input type="text" name="honeypot" tabindex="-1" autocomplete="off" class="hidden" />

  <label class="mt-4 flex items-start gap-2 text-sm text-slate-700">
    <input required type="checkbox" name="consent_to_contact" value="true" class="mt-1" />
    I agree to be contacted about my event request by phone, SMS, and email.
  </label>

  <button type="submit" data-submit-button class="mt-5 rounded-xl bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">
    Request My Quote
  </button>
  <p data-form-success class="mt-3 hidden text-sm font-medium text-emerald-700">
    Thanks. Your request was received and we will follow up shortly.
  </p>
  <p data-form-error class="mt-3 hidden text-sm font-medium text-rose-700"></p>
</form>

<script is:inline>
  (() => {
    const ATTR_KEYS = [
      "utm_source",
      "utm_medium",
      "utm_campaign",
      "utm_term",
      "utm_content",
      "gclid",
      "fbclid",
      "msclkid"
    ];

    function readAttrStore() {
      try {
        const session = JSON.parse(sessionStorage.getItem("hfla_attribution") || "{}");
        const local = JSON.parse(localStorage.getItem("hfla_attribution") || "{}");
        return { ...local, ...session };
      } catch {
        return {};
      }
    }

    function readUrlAttribution() {
      const out = {};
      try {
        const params = new URLSearchParams(window.location.search);
        ATTR_KEYS.forEach((key) => {
          const value = (params.get(key) || "").trim();
          if (value) {
            out[key] = value;
          }
        });
      } catch {
        /* noop */
      }
      return out;
    }

    function trackEvent(eventName, params = {}) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: eventName, ...params });
      if (typeof window.gtag === "function") {
        window.gtag("event", eventName, params);
      }
    }

    function getPayload(form) {
      const fd = new FormData(form);
      return {
        first_name: String(fd.get("first_name") || "").trim(),
        last_name: String(fd.get("last_name") || "").trim(),
        phone: String(fd.get("phone") || "").trim(),
        email: String(fd.get("email") || "").trim(),
        event_date: String(fd.get("event_date") || "").trim(),
        event_start_time: String(fd.get("event_start_time") || "").trim(),
        event_city: String(fd.get("event_city") || "").trim(),
        event_address_or_cross_streets_optional: String(fd.get("event_address_or_cross_streets_optional") || "").trim(),
        event_type: String(fd.get("event_type") || "").trim(),
        estimated_guest_count: String(fd.get("estimated_guest_count") || "").trim(),
        children_count_optional: String(fd.get("children_count_optional") || "").trim(),
        services_requested: fd.getAll("services_requested[]").map((value) => String(value).trim()).filter(Boolean),
        budget_range: String(fd.get("budget_range") || "").trim(),
        message: String(fd.get("message") || "").trim(),
        source_page: String(fd.get("source_page") || "").trim(),
        utm_source: String(fd.get("utm_source") || "").trim(),
        utm_medium: String(fd.get("utm_medium") || "").trim(),
        utm_campaign: String(fd.get("utm_campaign") || "").trim(),
        utm_term: String(fd.get("utm_term") || "").trim(),
        utm_content: String(fd.get("utm_content") || "").trim(),
        gclid: String(fd.get("gclid") || "").trim(),
        fbclid: String(fd.get("fbclid") || "").trim(),
        msclkid: String(fd.get("msclkid") || "").trim(),
        consent_to_contact: Boolean(fd.get("consent_to_contact")),
        honeypot: String(fd.get("honeypot") || "")
      };
    }

    function hydrateAttribution(form) {
      // Merge stored attribution with the current URL; the current landing URL
      // wins so first-touch ad params populate even before BaseLayout writes storage.
      const values = { ...readAttrStore(), ...readUrlAttribution() };
      ATTR_KEYS.forEach((key) => {
        const input = form.querySelector(`input[name="${key}"]`);
        if (!(input instanceof HTMLInputElement)) {
          return;
        }
        const next = String(values[key] || "").trim();
        // Only write non-empty values so blank/stale storage never clobbers a live URL value.
        if (next) {
          input.value = next;
        }
      });
      // Persist the merged (current-touch) attribution so later pages keep these values.
      try {
        const payload = JSON.stringify(values);
        sessionStorage.setItem("hfla_attribution", payload);
        localStorage.setItem("hfla_attribution", payload);
      } catch {
        // fail silently; the form must still submit visible fields
      }
    }

    /**
     * Prefill service checkboxes (and a helpful message) from a `?service=` URL param.
     * Accepted values: face-painting, balloon-twisting, glitter-tattoos, face-gems, party-package
     */
    function prefillFromQuery(form) {
      try {
        const params = new URLSearchParams(window.location.search);
        const requested = (params.get("service") || "").trim().toLowerCase();
        if (!requested) return;

        const map = {
          "face-painting": ["Face Painting"],
          "balloon-twisting": ["Balloon Twisting"],
          "glitter-tattoos": ["Glitter Tattoos"],
          "face-gems": ["Face Gems"],
          "party-package": ["Face Painting", "Balloon Twisting", "Glitter Tattoos", "Face Gems"],
        };
        const targets = map[requested];
        if (!targets) return;

        targets.forEach((value) => {
          const cb = form.querySelector(`input[name="services_requested[]"][value="${value}"]`);
          if (cb instanceof HTMLInputElement) {
            cb.checked = true;
          }
        });

        if (requested === "party-package") {
          const messageInput = form.querySelector('textarea[name="message"]');
          if (messageInput instanceof HTMLTextAreaElement && !messageInput.value.trim()) {
            messageInput.value =
              "I am considering a bundled party package. Please help me pick the right combination of services for my event size, age range, and schedule.";
          }
        }
      } catch {
        /* noop */
      }
    }

    const forms = document.querySelectorAll("form[data-quote-form]");
    forms.forEach((form) => {
      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      hydrateAttribution(form);
      prefillFromQuery(form);

      const sourceInput = form.querySelector('input[name="source_page"]');
      if (sourceInput instanceof HTMLInputElement && !sourceInput.value.trim()) {
        sourceInput.value = window.location.pathname;
      }

      const submitButton = form.querySelector("[data-submit-button]");
      const successNode = form.querySelector("[data-form-success]");
      const errorNode = form.querySelector("[data-form-error]");

      let hasStarted = false;
      const startTracking = () => {
        if (hasStarted) {
          return;
        }
        hasStarted = true;
        trackEvent("quote_form_start", { source_page: window.location.pathname });
      };

      form.addEventListener("input", startTracking);
      form.addEventListener("focusin", startTracking);

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.textContent = "Submitting...";
        }

        if (successNode instanceof HTMLElement) {
          successNode.classList.add("hidden");
        }

        if (errorNode instanceof HTMLElement) {
          errorNode.classList.add("hidden");
          errorNode.textContent = "";
        }

        // Refresh attribution at submit time so hidden fields reflect the current
        // URL/storage regardless of initial page-load script order.
        hydrateAttribution(form);
        const payload = getPayload(form);

        try {
          const response = await fetch("/api/lead", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload)
          });

          const result = await response.json().catch(() => ({ ok: false }));
          if (!response.ok || !result.ok) {
            const details = result?.errors ? ` ${Object.values(result.errors).join(" ")}` : "";
            throw new Error(`We could not submit your request.${details}`.trim());
          }

          trackEvent("quote_form_submit", { source_page: payload.source_page || window.location.pathname });
          trackEvent("generate_lead", {
            source_page: payload.source_page || window.location.pathname,
            lead_id: result.leadId || ""
          });

          form.reset();
          hydrateAttribution(form);

          const sourceAfterReset = form.querySelector('input[name="source_page"]');
          if (sourceAfterReset instanceof HTMLInputElement) {
            sourceAfterReset.value = window.location.pathname;
          }

          if (successNode instanceof HTMLElement) {
            successNode.classList.remove("hidden");
          }
        } catch (error) {
          if (errorNode instanceof HTMLElement) {
            errorNode.textContent = error instanceof Error ? error.message : "We could not submit your request. Please try again.";
            errorNode.classList.remove("hidden");
          }
        } finally {
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
            submitButton.textContent = "Request My Quote";
          }
        }
      });
    });
  })();
</script>
