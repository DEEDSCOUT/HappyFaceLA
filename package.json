{
  "name": "happyfacesla",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-date=2024-09-23",
    "build": "astro build && node scripts/build-manifest.mjs",
    "guard:owner-baseline": "node scripts/guard-owner-baseline.mjs",
    "test": "npm run test:lead-validation",
    "test:lead-validation": "node tests/api/lead-validation.mjs",
    "verify:release": "npm run guard:owner-baseline && npm run build",
    "qa:postbuild": "node scripts/qa-postbuild.mjs",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.3",
    "stripe": "^22.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "wrangler": "^4.92.0"
  }
}
