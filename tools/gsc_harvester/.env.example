# Required MCP connection
GSC_MCP_COMMAND=npx
GSC_MCP_ARGS_JSON=["-y","your-gsc-mcp-package-or-command"]

# Required GSC target property
GSC_SITE_URL=sc-domain:happyfacesla.com

# Tool names discovered from `npm run discover`
GSC_TOOL_SEARCH_ANALYTICS=get_search_analytics
GSC_TOOL_INDEXING_STATUS=inspect_url_enhanced
GSC_TOOL_SITEMAP_STATUS=get_sitemaps

# Pipeline tuning
GSC_OUTPUT_DIR=../../data/gsc
GSC_DAYS=30
GSC_ROW_LIMIT=1000
GSC_TOP_LIMIT=50
GSC_MIN_POSITION=5
GSC_MAX_POSITION=15
GSC_MAX_CTR=0.02
GSC_MIN_IMPRESSIONS=100

# Logging
LOG_LEVEL=info
