# Copy this file to .env.local (gitignored) and fill in values.
# DO NOT commit .env.local or any file containing real tokens.

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# OAuth callback port used by generate_refresh_token.py (default 53682).
# Change if that port is occupied (e.g. by Apache on 8080).
GOOGLE_ADS_OAUTH_PORT=53682

# Confirmed account topology:
#   Manager (MCC):  Happy Face LA   634-051-0052  (developer token lives here)
#   Client account: Happy Faces LA  468-234-8105  (diagnostics + mutations target this)
GOOGLE_ADS_CUSTOMER_ID=4682348105
GOOGLE_ADS_LOGIN_CUSTOMER_ID=6340510052

# Mutate gate. If false, every write tool refuses regardless of approval token.
GOOGLE_ADS_ALLOW_MUTATE=true
GOOGLE_ADS_REQUIRE_APPROVAL=true
GOOGLE_ADS_APPROVAL_TOKEN=I_APPROVE_GOOGLE_ADS_MUTATION
GOOGLE_ADS_DEFAULT_VALIDATE_ONLY=true
GOOGLE_ADS_MAX_DAILY_BUDGET_DELTA_PERCENT=25

GOOGLE_ADS_API_VERSION=v18
GOOGLE_ADS_MCP_LOG_LEVEL=INFO

# Output paths (relative to repo root)
GOOGLE_ADS_DOCS_DIR=docs/google-ads
