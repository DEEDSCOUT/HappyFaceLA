# Copy this file to .env.local (gitignored) and fill in values.
# DO NOT commit .env.local — it contains token path pointing to your OAuth credentials.

# Path to the OAuth2 token JSON generated by generate_token.py
GBP_TOKEN_FILE=C:\Dev\happyfacesla-commercial-control-room\.secrets\gbp_token.json

# Default GBP account resource name (run gbp_list_accounts to find it)
# Format: accounts/1234567890
GBP_ACCOUNT_NAME=

# Default location resource name (run gbp_list_locations to find it)
# Format: accounts/1234567890/locations/9876543210987654321
GBP_LOCATION_NAME=

# Mutation safety gate
# Set ALLOW_MUTATE=true to enable write tools (review replies, posts, location edits, etc.)
GBP_ALLOW_MUTATE=true
GBP_REQUIRE_APPROVAL=true
GBP_APPROVAL_TOKEN=I_APPROVE_GBP_MUTATION

GBP_MCP_LOG_LEVEL=INFO
