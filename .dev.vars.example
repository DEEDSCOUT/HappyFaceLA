# Local Wrangler secret overrides for Pages Functions development.
# Copy this template as .dev.vars and fill in real values.
# .dev.vars is gitignored — never commit real secrets.
# These values are injected as env vars into Pages Functions during: npm run pages:dev

OWNER_NOTIFICATION_EMAIL=local-test@example.com
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
GA4_MEASUREMENT_ID=
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_LEAD_CONVERSION_LABEL=

# --- Thumbtack Command Center (functions/api/thumbtack-webhook.ts) ---
# PRIMARY (Thumbtack Custom Header auth): Set THUMBTACK_WEBHOOK_TOKEN and configure
# Thumbtack webhook UI: Auth type = Custom Header, Header name = X-HFL-Webhook-Token,
# Header value = this token. Token takes priority over HMAC when both are set.
THUMBTACK_WEBHOOK_TOKEN=
# SECONDARY (HMAC, for Zapier/proxy paths that can compute a SHA256 sig):
THUMBTACK_WEBHOOK_SECRET=
SLACK_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
OWNER_SMS_TO=
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=
THUMBTACK_CRM_WEBHOOK_URL=
THUMBTACK_CRM_WEBHOOK_SECRET=
