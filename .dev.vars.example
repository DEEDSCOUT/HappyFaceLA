# Local Wrangler secret overrides for Pages Functions development.
# Copy this template as .dev.vars and fill in real values.
# .dev.vars is gitignored — never commit real secrets.
# These values are injected as env vars into Pages Functions during: npm run pages:dev

OWNER_NOTIFICATION_EMAIL=local-test@example.com
# CRM_WEBHOOK_URL: POST endpoint that receives the lead JSON payload.
# Production: deploy scripts/lead-webhook-apps-script.js as a Google Apps Script
# Web App and paste its URL here. See the script file for full setup instructions.
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
GA4_MEASUREMENT_ID=
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_LEAD_CONVERSION_LABEL=

# --- Thumbtack Command Center (functions/api/thumbtack-webhook.ts) ---
# Primary auth path for Thumbtack's Custom Header option.
# Configure Thumbtack with:
#   Header name: X-HFL-Webhook-Token
#   Header value: same value as THUMBTACK_WEBHOOK_TOKEN
THUMBTACK_WEBHOOK_TOKEN=
# Secondary HMAC path for proxy/Zapier flows only.
THUMBTACK_WEBHOOK_SECRET=
SLACK_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
OWNER_SMS_TO=
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=
THUMBTACK_CRM_WEBHOOK_URL=
THUMBTACK_CRM_WEBHOOK_SECRET=
